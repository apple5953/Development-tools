<Window x:Class="DevelopmentTools.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="磁磚鋪設系統 v3" Height="690" Width="320"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4CCFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5e81f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="SubtleBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2,10,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="🪟  Room Tile System"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#CBA6F7"/>
                <TextBlock Text="Author: MAYOUCHR"
                           FontSize="9" FontWeight="Medium"
                           Foreground="#89B4FA"
                           Margin="2,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Content="❓ 新手教學"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource SubtleBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="6,0"
                    VerticalAlignment="Center"
                    ToolTip="點擊開啟新手圖文快速入門與排障指南"/>
        </Grid>

        <!-- 主要鋪貼 -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="▍ 鋪設磁磚填充線（讀取現有材質描述）"
                       Style="{StaticResource SectionLabel}"/>
            <Button Content="📌  手動點選面 → 生成磁磚填充線"
                    Command="{Binding PickFaceCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    ToolTip="點選任意牆面或地板面，自動讀取描述欄位內的磁磚尺寸與縫隙，疊加填充線（不動原有材質）"/>
            <Button Content="✔️  1. 確認鋪貼並改寫原材質圖案"
                    Command="{Binding ConfirmMaterialPatCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#A6E3A1"
                    ToolTip="選取已 Paint 暫時填充線的面，將其確認為正式貼面並修改原有裝修層材質的前景 .pat 填充線"/>
            <Button Content="🧱  2-1. 建立 3D 牆面磁磚實體"
                    Command="{Binding Generate3DTilesCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#89B4FA"
                    ToolTip="點選已改寫前景填充線的牆面，依結構厚度生成 3D 牆面磁磚實體"/>
            <Button Content="🟫  2-2. 建立 3D 地坪磁磚實體"
                    Command="{Binding Generate3DFloorTilesCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#FAB387"
                    ToolTip="點選已改寫前景填充線的地坪面，依結構厚度生成 3D 地坪磁磚實體"/>
            <Button Content="🎨  局部變更磁磚材質"
                    Command="{Binding ChangeLocalTileMaterialCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F5C2E7"
                    Foreground="#1E1E2E"
                    ToolTip="選取多塊已生成的 3D 磁磚，批次變更其局部材質與樣式"/>
            <Button Content="📐  轉換為可編輯磁磚"
                    Command="{Binding ConvertToEditableCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    ToolTip="點選不可調整的 3D 磁磚，原地轉換為原生 Walls / Floors 元件，即可雙擊 Edit Profile 進行修改"/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📊 3. 平面幾何統計"
                        Command="{Binding CalculatePlaneQuantityCommand}"
                        Style="{StaticResource SubtleBtn}"
                        Background="#F9E2AF"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="多選已改寫前景填充線的正式面，藉由幾何排版引擎估算數量"/>
                <Button Grid.Column="2" Content="🔍 4. 3D 實體統計"
                        Command="{Binding Calculate3DQuantityCommand}"
                        Style="{StaticResource SubtleBtn}"
                        Background="#F5C2E7"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="多選房間元件，統計選定空間內所有已生成的 3D 磁磚實體與損耗率"/>
            </Grid>
            <TextBlock Text="▍ 統計與明細表匯出" Style="{StaticResource SectionLabel}"/>
            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📄 建立 Revit 明細表"
                        Command="{Binding CreateScheduleCommand}"
                        Style="{StaticResource GreenBtn}"
                        Background="#FAB387"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="在專案中建立常規模型磁磚明細表"/>
                <Button Grid.Column="2" Content="📥 匯出 Excel 統計表"
                        Command="{Binding ExportExcelCommand}"
                        Style="{StaticResource GreenBtn}"
                        Background="#A6E3A1"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="收集專案中所有磁磚資料，匯出為 Excel / CSV 統計報表"/>
            </Grid>
        </StackPanel>

        <!-- 縫隙參數 -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="▍ 加入縫隙寬度參數（首次使用時點擊）"
                       Style="{StaticResource SectionLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="🧱 裝修牆縫隙參數"
                        Command="{Binding AddJointWallsCommand}"
                        Style="{StaticResource GreenBtn}"
                        ToolTip="在所有裝修牆的屬性面板新增「Tile_Joint_Width」欄位（mm），預設 3mm，可個別修改後再執行鋪貼"/>
                <Button Grid.Column="2"
                        Content="🟫 裝修地板縫隙參數"
                        Command="{Binding AddJointFloorsCommand}"
                        Style="{StaticResource GreenBtn}"
                        ToolTip="在所有裝修地板的屬性面板新增「Tile_Joint_Width」欄位（mm），預設 3mm，可個別修改後再執行鋪貼"/>
            </Grid>
        </StackPanel>

        <!-- 次要操作 -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="▍ 其他" Style="{StaticResource SectionLabel}"/>
            <Button Content="移除已疊加的填充線（不影響原有材質）"
                    Command="{Binding DeleteTilesCommand}"
                    Style="{StaticResource SubtleBtn}"
                    ToolTip="只移除本外掛疊加的磁磚填充線 Paint，不會修改或刪除 any 原有材質設定"/>
            <Button Content="💬 問題與意見反饋"
                    Click="BtnFeedback_Click"
                    Style="{StaticResource SubtleBtn}"
                    Background="#89DCEB"
                    Foreground="#1E1E2E"
                    Margin="0,4,0,0"
                    ToolTip="向作者提交功能優化反饋或錯誤回報"/>
        </StackPanel>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                Margin="0,10,0,0" Padding="8,6" MinHeight="80">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#A6E3A1"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           VerticalAlignment="Top"/>
                <TextBlock Text="MACHR"
                           Foreground="#6C7086"
                           FontSize="9"
                           FontStyle="Italic"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Opacity="0.85"/>
            </Grid>
        </Border>
    </Grid>
</Window>
