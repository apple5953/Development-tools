<Window x:Class="DevelopmentTools.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:DevelopmentTools.Core"
        Title="{Binding [TileSys_Title], Source={x:Static core:LanguageManager.Instance}}" Height="690" Width="320"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4CCFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5e81f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="SubtleBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2,10,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="🪟  Room Tile System"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#CBA6F7"/>
                <TextBlock Text="Author: MAYOUCHR"
                           FontSize="9" FontWeight="Medium"
                           Foreground="#89B4FA"
                           Margin="2,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Content="{Binding [TileSys_Tutorial], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource SubtleBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="6,0"
                    VerticalAlignment="Center"
                    ToolTip="{Binding [TileSys_TutorialDesc], Source={x:Static core:LanguageManager.Instance}}"/>
        </Grid>

        <!-- 主要鋪貼 -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding [TileSys_Mode1], Source={x:Static core:LanguageManager.Instance}}"
                       Style="{StaticResource SectionLabel}"/>
            <Button Content="{Binding [TileSys_Mode1_Btn_Alt], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding PickFaceCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    ToolTip="{Binding [TileSys_Desc_GenLayout], Source={x:Static core:LanguageManager.Instance}}"/>
            <Button Content="{Binding [TileSys_Mode1_Confirm_Alt], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding ConfirmMaterialPatCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#A6E3A1"
                    ToolTip="{Binding [TileSys_Desc_ConfirmPaint], Source={x:Static core:LanguageManager.Instance}}"/>
            <Button Content="{Binding [TileSys_Gen3DWall2_Alt], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding Generate3DTilesCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#89B4FA"
                    ToolTip="{Binding [TileSys_Desc_Gen3DWall], Source={x:Static core:LanguageManager.Instance}}"/>
            <Button Content="{Binding [TileSys_Gen3DFloor2_Alt], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding Generate3DFloorTilesCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#FAB387"
                    ToolTip="{Binding [TileSys_Desc_Gen3DFloor], Source={x:Static core:LanguageManager.Instance}}"/>
            <Button Content="{Binding [TileSys_ChangeTileMaterial2_Alt], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding ChangeLocalTileMaterialCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F5C2E7"
                    Foreground="#1E1E2E"
                    ToolTip="{Binding [TileSys_Desc_ChangeTileMaterial], Source={x:Static core:LanguageManager.Instance}}"/>
            <Button Content="{Binding [TileSys_ConvertToEditable2_Alt], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding ConvertToEditableCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    ToolTip="{Binding [TileSys_Desc_ConvertToEditable], Source={x:Static core:LanguageManager.Instance}}"/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{Binding [TileSys_Stats2D], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding CalculatePlaneQuantityCommand}"
                        Style="{StaticResource SubtleBtn}"
                        Background="#F9E2AF"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="{Binding [TileSys_Desc_Stats2D], Source={x:Static core:LanguageManager.Instance}}"/>
                <Button Grid.Column="2" Content="{Binding [TileSys_Stats3D], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding Calculate3DQuantityCommand}"
                        Style="{StaticResource SubtleBtn}"
                        Background="#F5C2E7"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="{Binding [TileSys_Desc_Stats3D], Source={x:Static core:LanguageManager.Instance}}"/>
            </Grid>
            <TextBlock Text="{Binding [TileSys_ExportSection], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SectionLabel}"/>
            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{Binding [TileSys_CreateSchedule], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding CreateScheduleCommand}"
                        Style="{StaticResource GreenBtn}"
                        Background="#FAB387"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="{Binding [TileSys_Desc_CreateSchedule], Source={x:Static core:LanguageManager.Instance}}"/>
                <Button Grid.Column="2" Content="{Binding [TileSys_ExportExcel], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding ExportExcelCommand}"
                        Style="{StaticResource GreenBtn}"
                        Background="#A6E3A1"
                        Foreground="#1E1E2E"
                        Height="32"
                        ToolTip="{Binding [TileSys_Desc_ExportExcel], Source={x:Static core:LanguageManager.Instance}}"/>
            </Grid>
        </StackPanel>

        <!-- 縫隙參數 -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="{Binding [TileSys_AddJointParam], Source={x:Static core:LanguageManager.Instance}}"
                       Style="{StaticResource SectionLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="{Binding [TileSys_WallJointParam], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding AddJointWallsCommand}"
                        Style="{StaticResource GreenBtn}"
                        ToolTip="{Binding [TileSys_Desc_WallJointParam], Source={x:Static core:LanguageManager.Instance}}"/>
                <Button Grid.Column="2"
                        Content="{Binding [TileSys_FloorJointParam2], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding AddJointFloorsCommand}"
                        Style="{StaticResource GreenBtn}"
                        ToolTip="{Binding [TileSys_Desc_FloorJointParam], Source={x:Static core:LanguageManager.Instance}}"/>
            </Grid>
        </StackPanel>

        <!-- 次要操作 -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="{Binding [TileSys_OtherSection], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SectionLabel}"/>
            <Button Content="{Binding [TileSys_Desc_DeleteLayout], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding DeleteTilesCommand}"
                    Style="{StaticResource SubtleBtn}"
                    ToolTip="{Binding [TileSys_Desc_ResetOrigin], Source={x:Static core:LanguageManager.Instance}}"/>
            <Button Content="{Binding [TileSys_Feedback], Source={x:Static core:LanguageManager.Instance}}"
                    Click="BtnFeedback_Click"
                    Style="{StaticResource SubtleBtn}"
                    Background="#89DCEB"
                    Foreground="#1E1E2E"
                    Margin="0,4,0,0"
                    ToolTip="{Binding [TileSys_Desc_Feedback], Source={x:Static core:LanguageManager.Instance}}"/>
        </StackPanel>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                Margin="0,10,0,0" Padding="8,6" MinHeight="80">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#A6E3A1"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           VerticalAlignment="Top"/>
                <TextBlock Text="MACHR"
                           Foreground="#6C7086"
                           FontSize="9"
                           FontStyle="Italic"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Opacity="0.85"/>
            </Grid>
        </Border>
    </Grid>
</Window>
