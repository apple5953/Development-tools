<Window x:Class="DevelopmentTools.UI.FeedbackWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:DevelopmentTools.Core"

        Title="{Binding [Feedback_Title], Source={x:Static core:LanguageManager.Instance}}" Height="450" Width="360"

        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"

        WindowStartupLocation="CenterOwner"

        ResizeMode="NoResize"

        ShowInTaskbar="False">

    

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>


        <Style x:Key="TextBoxStyle" TargetType="TextBox">

            <Setter Property="Background" Value="#313244"/>

            <Setter Property="Foreground" Value="#CDD6F4"/>

            <Setter Property="BorderBrush" Value="#45475A"/>

            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Padding" Value="6,4"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border Background="{TemplateBinding Background}"

                                BorderBrush="{TemplateBinding BorderBrush}"

                                BorderThickness="{TemplateBinding BorderThickness}"

                                CornerRadius="4">

                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="SubmitBtn" TargetType="Button">

            <Setter Property="Background" Value="#A6E3A1"/>

            <Setter Property="Foreground" Value="#1E1E2E"/>

            <Setter Property="FontWeight" Value="Bold"/>

            <Setter Property="FontSize" Value="12"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Height" Value="34"/>

            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}" CornerRadius="4">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Background" Value="#B4F4AF"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter Property="Background" Value="#86C381"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>



    <Grid Margin="18">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <!-- 標題 -->

        <TextBlock Grid.Row="0" Text="{Binding [Feedback_SubmitTitle], Source={x:Static core:LanguageManager.Instance}}" 

                   FontSize="14" FontWeight="Bold" Foreground="#CBA6F7" Margin="0,0,0,10"/>



        <!-- 帳號 -->

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">

            <TextBlock Text="{Binding [Feedback_Account], Source={x:Static core:LanguageManager.Instance}}" Foreground="#6C7086" FontSize="11"/>

            <TextBlock x:Name="TxtEmail" Text="loading..." Foreground="#89B4FA" FontSize="11" FontWeight="Bold"/>

        </StackPanel>



        <!-- 標題輸入 -->

        <StackPanel Grid.Row="2" Margin="0,0,0,10">

            <TextBlock Text="{Binding [Feedback_Topic], Source={x:Static core:LanguageManager.Instance}}" Foreground="#BAC2E0" FontSize="11" Margin="0,0,0,4"/>

            <TextBox x:Name="TxtTitle" Style="{StaticResource TextBoxStyle}" Height="28"/>

        </StackPanel>



        <!-- 內容描述 -->

        <Grid Grid.Row="3" Margin="0,0,0,12">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding [Feedback_Desc], Source={x:Static core:LanguageManager.Instance}}" Foreground="#BAC2E0" FontSize="11" Margin="0,0,0,4"/>

            <Grid Grid.Row="1">

                <TextBox x:Name="TxtDescription" Style="{StaticResource TextBoxStyle}" 

                          AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="Auto"/>

                <TextBlock Text="{Binding [Feedback_Template], Source={x:Static core:LanguageManager.Instance}}"

                           Foreground="#585B70" FontSize="11" Margin="8,8" IsHitTestVisible="False" VerticalAlignment="Top" TextWrapping="Wrap">

                    <TextBlock.Style>

                        <Style TargetType="TextBlock">

                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding ElementName=TxtDescription, Path=Text}" Value="">

                                    <Setter Property="Visibility" Value="Visible"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </TextBlock.Style>

                </TextBlock>

            </Grid>

        </Grid>



        <!-- 按鈕與狀態 -->

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtStatus" Grid.Column="0" Text="" Foreground="#F38BA8" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>

            <Button x:Name="BtnSubmit" Grid.Column="1" Content="{Binding [Feedback_SubmitBtn], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SubmitBtn}" Width="100" Click="BtnSubmit_Click"/>

        </Grid>

    </Grid>

</Window>

