                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgPrimary}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="機電管線穿梁牆套管遺漏檢討" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,6,0,0" Visibility="{Binding IsChecking, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding RunCheckCommand}" Content="⚡ 重新執行檢核" Style="{StaticResource BtnPrimary}" Height="34" Padding="12,0" VerticalAlignment="Center"/>
                                </Grid>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding Issues}" SelectedItem="{Binding SelectedIssue, Mode=TwoWay}" Style="{StaticResource DataGridStyle}">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyle}"/>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource CellStyle}"/>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="等級" Binding="{Binding SeverityIcon}" Width="50"/>
                                        <DataGridTextColumn Header="管線名稱/ID" Binding="{Binding ElementName}" Width="120" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="尺寸" Binding="{Binding MepSize}" Width="90"/>
                                        <DataGridTextColumn Header="穿透結構件" Binding="{Binding StructureElementName}" Width="*"/>
                                        <DataGridTextColumn Header="樓層" Binding="{Binding LevelName}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" Background="{StaticResource BorderColor}" HorizontalAlignment="Stretch"/>

                        <Border Grid.Column="2" Background="{StaticResource BgPanel}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Visibility="{Binding HasSelectedIssue, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="診斷缺失詳情" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedIssue.ElementName}" Foreground="{StaticResource AccentBlue}" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedIssue.MepCategoryName, StringFormat='管線類別: {0}'}" Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding SelectedIssue.ElementId, StringFormat='管線 ID: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="說明" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedIssue.Description}" Foreground="{StaticResource TextPrimary}" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,16"/>
                                    
                                    <TextBlock Text="碰撞交叉點 (XYZ)" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedIssue.Location}" Foreground="{StaticResource TextSecondary}" FontSize="13" FontFamily="Consolas"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Visibility="{Binding HasSelectedIssue, Converter={StaticResource BoolToVis}}">
                                    <Button Command="{Binding ShowIssueIn3DCommand}" Content="👁 在 3D 剖面中對焦定位" Style="{StaticResource BtnPrimary}" Height="36" Margin="0,0,0,10"/>
                                    <Button Command="{Binding AutoFixCommand}" Content="🔧 一鍵放置套管開孔" Style="{StaticResource BtnSuccess}" Height="36"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DataTemplate>

    <!-- 🏠 6. 房間裝修幾何一致性檢核 View Template -->
    <DataTemplate DataType="{x:Type vm:RoomFinishReviewViewModel}">
        <TabControl Style="{StaticResource HiddenTabControlStyle}" SelectedIndex="{Binding SelectedSubTabIndex}">
            
            <TabItem>
                <Border Background="{StaticResource BgPrimary}" Padding="20"><Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Binding RegRuleName}" Foreground="{StaticResource AccentBlue}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding RegRuleDescription}" Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,6,0,12" TextWrapping="Wrap" LineHeight="18"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="所需模型元件" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding RequiredComponentsText}" Foreground="{StaticResource TextPrimary}" FontSize="13" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="所需參數與配置欄位" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding RequiredParametersText}" Foreground="{StaticResource TextPrimary}" FontSize="13" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📋 模型前置健康度診斷表" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding PreCheckItems}" SelectedItem="{Binding SelectedPreCheckItem, Mode=TwoWay}" Style="{StaticResource DataGridStyle}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyle}"/>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource CellStyle}"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="檢查對象" Binding="{Binding TargetName}" Width="220" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="完備狀態" Binding="{Binding Status}" Width="180"/>
                                <DataGridTextColumn Header="影響與限制說明" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding RunPreCheckCommand}" Content="⚡ 重新整理診斷" Style="{StaticResource BtnSecondary}" Height="36" Padding="16,0" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Command="{Binding SelectMissingElementsCommand}" Content="👁 在 Revit 中選取/定位缺失元件" Style="{StaticResource BtnSecondary}" Height="36" Padding="16,0"/>
                        <Button Grid.Column="3" Command="{Binding SwitchToResultsCommand}" Content="進入檢核結果列表 ➔" Style="{StaticResource BtnPrimary}" Height="36" Padding="20,0"/>
                    </Grid>
                </Grid></Border>
            </TabItem>

            <TabItem>
                <Grid Style="{StaticResource SubViewGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="16,10">
                        <Button Command="{Binding SwitchToPreCheckCommand}" Content="⬅ 返回法規說明與健康診斷" Style="{StaticResource BtnSecondary}" Height="28" Padding="12,0" HorizontalAlignment="Left"/>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgPrimary}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="房間裝修幾何一致性檢討" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,6,0,0" Visibility="{Binding IsChecking, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding RunCheckCommand}" Content="⚡ 重新執行檢核" Style="{StaticResource BtnPrimary}" Height="34" Padding="12,0" VerticalAlignment="Center"/>
                                </Grid>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding Issues}" SelectedItem="{Binding SelectedIssue, Mode=TwoWay}" Style="{StaticResource DataGridStyle}">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyle}"/>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource CellStyle}"/>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="等級" Binding="{Binding SeverityIcon}" Width="50"/>
                                        <DataGridTextColumn Header="房間名稱" Binding="{Binding ElementName}" Width="150" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="說明" Binding="{Binding Description}" Width="*"/>
                                        <DataGridTextColumn Header="樓層" Binding="{Binding LevelName}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" Background="{StaticResource BorderColor}" HorizontalAlignment="Stretch"/>

                        <Border Grid.Column="2" Background="{StaticResource BgPanel}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Visibility="{Binding HasSelectedIssue, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="診斷缺失詳情" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedIssue.ElementName}" Foreground="{StaticResource AccentBlue}" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedIssue.LevelName, StringFormat='所在樓層: {0}'}" Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding SelectedIssue.ElementId, StringFormat='房間 ID: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="說明" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedIssue.Description}" Foreground="{StaticResource TextPrimary}" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,16"/>
                                </StackPanel>

                                <Button Grid.Row="1" Command="{Binding ShowIssueIn3DCommand}" Content="👁 在 3D 剖面中對焦定位" Style="{StaticResource BtnPrimary}" Height="36" Visibility="{Binding HasSelectedIssue, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DataTemplate>

    <!-- 📜 中華民國建築技術規則與輔助法規庫 View Template -->
    <DataTemplate DataType="{x:Type vm:RegulatoryCodesCatalogViewModel}">
        <Grid Style="{StaticResource SubViewGrid}" Background="{StaticResource BgPrimary}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/> <!-- 左側法規條款目錄 -->
                <ColumnDefinition Width="1"/>   <!-- 分隔線 -->
                <ColumnDefinition Width="*"/>   <!-- 右側診斷與詳細說明 -->
            </Grid.ColumnDefinitions>

            <!-- 左側法規目錄 -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="📜 中華民國建築技術規則庫" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="逐條對照 Revit 模型元件之參數健康度" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                        <ListBox.Resources>
                            <!-- 複寫選單樣式，使其顯示狀態與法條 -->
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                <Setter Property="Padding" Value="12,12"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1E293B"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0F172A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:RegulatoryCodeRule}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 國家標誌 -->
                                    <Border Grid.RowSpan="2" Grid.Column="0" Background="#1E293B" CornerRadius="4" Padding="6,4" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Country}" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="Bold"/>
                                    </Border>

                                    <!-- 法規名稱 -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Section}" Foreground="{StaticResource AccentBlue}" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding RuleName}" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- 狀態提示 -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="診斷:" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding HealthStatus}" FontSize="13" FontWeight="SemiBold" Margin="0,0,12,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="✅ 參數齊備">
                                                            <Setter Property="Foreground" Value="#30D158"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="⚠️ 參數不完備">
                                                            <Setter Property="Foreground" Value="#FF9F0A"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="❌ 缺少元件">
                                                            <Setter Property="Foreground" Value="#FF453A"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text="執行:" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding RunStatus}" FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="✅ 符合法規">
                                                            <Setter Property="Foreground" Value="#30D158"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="⚪ 未執行">
                                                            <Setter Property="Foreground" Value="#BAC5D5"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="需人工目視審查">
                                                            <Setter Property="Foreground" Value="#BAC5D5"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="請直接由左側對應幾何檢核頁面執行運算">
                                                            <Setter Property="Foreground" Value="#BAC5D5"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 分隔線 -->
            <GridSplitter Grid.Column="1" Background="{StaticResource BorderColor}" HorizontalAlignment="Stretch"/>

            <!-- 右側詳細說明與診斷 -->
            <Border Grid.Column="2" Padding="20">
                <Grid Visibility="{Binding HasSelectedRule, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- 頂部法條詳情 -->
                        <RowDefinition Height="*"/>    <!-- 中間健康度診斷 DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- 底部控制與結果 -->
                    </Grid.RowDefinitions>

                    <!-- 頂部法條詳情 -->
                    <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedRule.Chapter}" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding SelectedRule.Section}" Foreground="{StaticResource AccentBlue}" FontSize="18" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding SelectedRule.RuleName}" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#0F172A" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="8,4" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="比對方式: " Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                        <TextBlock Text="{Binding SelectedRule.CheckMethod}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Separator Background="{StaticResource BorderColor}" Margin="0,12"/>

                            <TextBlock Text="法條說明與檢核邏輯" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedRule.Description}" Foreground="{StaticResource TextPrimary}" FontSize="14" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,12"/>
                        </StackPanel>
                    </Border>

                    <!-- 中間健康度前置診斷表 -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📋 欄位健康度前置診斷 (Revit 元件參數完整性)" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding PreCheckItems}" Style="{StaticResource DataGridStyle}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource HeaderStyle}"/>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource CellStyle}"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="診斷對象" Binding="{Binding TargetName}" Width="200" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <!-- 對於缺失/警告 -->
                                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF453A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="診斷說明" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- 底部控制與結果 -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap"/>
                                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,8,0,0" Visibility="{Binding IsChecking, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{Binding RunCheckCommand}" Content="⚡ 執行參數合規檢查" Style="{StaticResource BtnPrimary}" Height="38" Padding="20,0" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
