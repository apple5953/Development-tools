<Page x:Class="DevelopmentTools.Modules.DesignReview.Views.CodeReviewPanePage"
      x:Name="PanePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:DevelopmentTools.Modules.DesignReview.ViewModels"
      xmlns:models="clr-namespace:DevelopmentTools.Modules.DesignReview.Models"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="360"
      Title="CodeReviewPanePage">

    <Page.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BgPrimary" Color="#07090E"/>
            <SolidColorBrush x:Key="BgPanel" Color="#0F141C"/>
            <SolidColorBrush x:Key="BgCard" Color="#161D26"/>
            <SolidColorBrush x:Key="AccentBlue" Color="#388BFD"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#BAC5D5"/>
            <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            
            <Style x:Key="DarkTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource BgCard}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            </Style>

            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="#238636"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2ea043"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="{StaticResource BgPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 頂部過濾與控制 -->
            <RowDefinition Height="*"/>    <!-- 法規與異常條目 -->
            <RowDefinition Height="Auto"/> <!-- 詳細說明與異常 DataGrid -->
            <RowDefinition Height="Auto"/> <!-- 追蹤修改面板 -->
        </Grid.RowDefinitions>

        <!-- 頂部過濾與控制 -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍 BCR 法規檢討" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Command="{Binding RecheckCommand}" Content="⚡ 重新檢查" Style="{StaticResource BtnPrimary}" Padding="8,4" FontSize="11"/>
                    <Button Grid.Column="3" Command="{Binding CreateSheetCommand}" Content="📊 產生成果圖紙" Style="{StaticResource BtnPrimary}" Padding="8,4" FontSize="11"/>
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategoryFilter}" Height="28"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatusFilter}" Height="28"/>
                </Grid>
                
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🎯 檢討視角:" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Width="65"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding Perspectives}" SelectedItem="{Binding SelectedPerspectiveFilter}" Height="28"/>
                </Grid>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🏢 建物用途:" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Width="65"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding BuildingTypes}" SelectedItem="{Binding SelectedBuildingType}" Height="28"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 法規與異常條目 -->
        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredItems}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ReviewItem}">
                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="8" HorizontalAlignment="Stretch" Width="320">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="{Binding RuleCode}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12.5" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <Border Background="#D97706" CornerRadius="3" Padding="4,1" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LawArticle}" Foreground="White" FontSize="9.5" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="{Binding RuleName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12.5" TextTrimming="CharacterEllipsis" Width="160" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Border Grid.Row="0" Grid.Column="2" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Created">
                                                <Setter Property="Background" Value="#8B2635"/> <!-- 質感紅 -->
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Modified">
                                                <Setter Property="Background" Value="#A07810"/> <!-- 質感黃 -->
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                <Setter Property="Background" Value="#2A7B4C"/> <!-- 質感綠 -->
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                <Setter Property="Background" Value="#883D94"/> <!-- 質感紫 -->
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusDisplay}" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding Description}" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="14"/>

                            <!-- 偵測與標準 -->
                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,6" Margin="0,6,0,4">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="10.5" LineHeight="14">
                                        <Run Text="🔍 偵測: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                        <Run Text="{Binding DetectElements, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="10.5" Margin="0,2,0,0" TextWrapping="Wrap" LineHeight="14">
                                        <Run Text="🎯 標準: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                        <Run Text="{Binding CheckCriteria, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 執行按鈕 -->
                            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                    Command="{Binding DataContext.SingleRecheckCommand, ElementName=PanePage}"
                                    CommandParameter="{Binding}"
                                    Content="⚡ 執行檢討"
                                    Style="{StaticResource BtnPrimary}"
                                    HorizontalAlignment="Right"
                                    Padding="10,3"
                                    FontSize="10.5"
                                    Height="22"
                                    Margin="0,2,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 詳細說明與異常 DataGrid -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,1" Padding="12" Height="270" Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="📖 法規條文詳細說明" Foreground="{StaticResource AccentBlue}" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                
                <ScrollViewer Grid.Row="1" Height="75" VerticalScrollBarVisibility="Auto" Background="{StaticResource BgCard}" Padding="6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedItem.Description}" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" LineHeight="14"/>
                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Margin="0,6,0,0" Padding="0,6,0,0">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" LineHeight="14">
                                    <Run Text="🔍 偵測元件: " FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    <Run Text="{Binding SelectedItem.DetectElements, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" LineHeight="14">
                                    <Run Text="🎯 評判標準: " FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    <Run Text="{Binding SelectedItem.CheckCriteria, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2" Text="⚠️ 異常元件列表 (雙擊對焦選取)" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                
                <DataGrid Grid.Row="3" ItemsSource="{Binding SelectedItem.Results}" SelectedItem="{Binding SelectedResult, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" Background="{StaticResource BgCard}" BorderThickness="0" RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="位置" Binding="{Binding LevelName}" Width="60"/>
                        <DataGridTextColumn Header="元件ID" Binding="{Binding ElementId}" Width="80"/>
                        <DataGridTextColumn Header="說明" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" 
                                      Command="{Binding DataContext.DoubleClickResultCommand, RelativeSource={RelativeSource AncestorType=Page}}"/>
                    </DataGrid.InputBindings>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 追蹤修改面板 -->
        <Border Grid.Row="3" Background="{StaticResource BgPanel}" Padding="12" Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="指派給: " Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Width="50"/>
                    <TextBox Grid.Column="1" Text="{Binding AssigneeInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Height="24"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="備註: " Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Width="50"/>
                    <TextBox Grid.Column="1" Text="{Binding CommentInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Height="24"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" SelectedItem="{Binding SelectedStatusInput}" Height="26">
                        <models:TrackingStatus>Created</models:TrackingStatus>
                        <models:TrackingStatus>Modified</models:TrackingStatus>
                        <models:TrackingStatus>Approved</models:TrackingStatus>
                        <models:TrackingStatus>Rejected</models:TrackingStatus>
                    </ComboBox>
                    <Button Grid.Column="2" Command="{Binding UpdateStatusCommand}" Content="更新狀態" Style="{StaticResource BtnPrimary}" Padding="12,4" FontSize="11"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
