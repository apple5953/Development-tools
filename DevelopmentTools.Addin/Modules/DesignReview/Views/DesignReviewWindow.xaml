<Window x:Class="DevelopmentTools.Modules.DesignReview.Views.DesignReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM 事前檢核與設計審查系統" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#07090E"
        FontFamily="Microsoft JhengHei UI">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DesignReviewSubViews.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="BgPrimary" Color="#07090E"/>
            <SolidColorBrush x:Key="BgPanel" Color="#0F141C"/>
            <SolidColorBrush x:Key="BgCard" Color="#161D26"/>
            <SolidColorBrush x:Key="AccentBlue" Color="#388BFD"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#BAC5D5"/>
            <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>

            <!-- ListBox Item 樣式複寫，使其顯得極具高級感 -->
            <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#21262D"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#30363D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Panel -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔍 BIM 事前檢核與可施工性設計審查" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="在施工前分項定位法規與設計合理性缺陷，減少現場敲鑿修改及衝突率。" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="狀態: " Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#85EA2D" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Navigation Menu -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📊 選擇檢核項目" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}" ItemContainerStyle="{StaticResource NavItemStyle}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 調整圖示為 Emojis -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Icon}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" Foreground="{StaticResource TextSecondary}" FontSize="13" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="14"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Background="{StaticResource BorderColor}" HorizontalAlignment="Stretch"/>

            <!-- Right Content Area (Loads Sub-Views dynamically) -->
            <ContentControl Grid.Column="2" Content="{Binding CurrentSubViewModel}" />
        </Grid>
    </Grid>
</Window>
