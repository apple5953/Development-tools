<Window x:Class="DevelopmentTools.Modules.SheetTransfer.Views.SheetTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DevelopmentTools.Modules.SheetTransfer.Views"
        Title="跨專案圖紙轉移工具" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        FontFamily="Microsoft JhengHei UI"
        Closing="Window_Closing">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0F1117"/>
        <SolidColorBrush x:Key="BgPanel" Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard" Color="#1C2128"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#388BFD"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7D8590"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Panel: Project Selection -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="來源專案" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SourceFilePath, TargetNullValue='尚未選擇檔案'}" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding SourceProjectName, StringFormat='專案名稱: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SourceRevitVersion, StringFormat='Revit 版本: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding BrowseCommand}" Content="瀏覽來源檔案..." Style="{StaticResource BtnPrimary}" VerticalAlignment="Center" IsEnabled="{Binding IsAnalyzing, Converter={x:Static local:BoolToInvertConverter.Instance}}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Info -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="轉移狀態" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBlue}" TextWrapping="Wrap" FontSize="14"/>
                    
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0" Visibility="{Binding IsAnalyzing, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0" Foreground="#3FB950" Visibility="{Binding IsTransferring, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}"/>

            <!-- Middle: Asset Tree -->
            <Border Grid.Column="2" Background="{StaticResource BgPrimary}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="資產清單" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TreeView Grid.Row="1" ItemsSource="{Binding AssetGroups}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Assets}">
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Assets.Count, StringFormat=' ({0})'}" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Number, StringFormat='{}{0} '}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <Button Grid.Row="2" Command="{Binding TransferCommand}" Content="開始轉移" Style="{StaticResource BtnPrimary}" Margin="0,16,0,0" IsEnabled="{Binding CanTransfer}"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}"/>

            <!-- Right: Report -->
            <Border Grid.Column="4" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="轉移報告" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBox Grid.Row="1" Text="{Binding ReportText, Mode=OneWay}" Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}" BorderThickness="0" FontFamily="Consolas" IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
