<Window x:Class="DevelopmentTools.Modules.SheetTransfer.Views.SheetTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DevelopmentTools.Modules.SheetTransfer.Views"
        Title="跨專案圖紙轉移工具" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        FontFamily="Microsoft JhengHei UI"
        Closing="Window_Closing">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0F1117"/>
        <SolidColorBrush x:Key="BgPanel" Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard" Color="#1C2128"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#388BFD"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7D8590"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Panel: Project Selection -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左側：已選取來源的資訊 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="來源專案" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SourceFilePath, TargetNullValue='尚未選擇來源 (請從右側選單選取已開啟專案或瀏覽本地檔案)'}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding SourceProjectName, StringFormat='專案名稱: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SourceRevitVersion, StringFormat='Revit 版本: {0}'}" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center" Background="{StaticResource BorderColor}" Margin="20,0"/>

                <!-- 右側：選擇管道 -->
                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="💡 提示：若要同步 ACC 雲端模型，請先在 Revit 中開啟它，並在此選取" Foreground="#85EA2D" FontSize="11" Margin="0,0,0,6"/>

                    <ComboBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding OpenProjects}" SelectedItem="{Binding SelectedOpenProject}" Height="34" VerticalContentAlignment="Center" Background="#1C2128" Foreground="White" BorderBrush="{StaticResource BorderColor}" Margin="0,0,10,0" IsEnabled="{Binding IsAnalyzing, Converter={x:Static local:BoolToInvertConverter.Instance}}"/>
                    <Button Grid.Row="1" Grid.Column="1" Command="{Binding BrowseCommand}" Content="瀏覽本地檔案..." Style="{StaticResource BtnPrimary}" Height="34" Padding="12,0" VerticalAlignment="Center" IsEnabled="{Binding IsAnalyzing, Converter={x:Static local:BoolToInvertConverter.Instance}}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Info -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="轉移狀態" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBlue}" TextWrapping="Wrap" FontSize="14"/>
                    
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0" Visibility="{Binding IsAnalyzing, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0" Foreground="#3FB950" Visibility="{Binding IsTransferring, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}"/>

            <!-- Middle: Asset Tree -->
            <Border Grid.Column="2" Background="{StaticResource BgPrimary}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="資產清單" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TreeView Grid.Row="1" ItemsSource="{Binding AssetGroups}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Assets}">
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Assets.Count, StringFormat=' ({0})'}" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Number, StringFormat='{}{0} '}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ComparisonText}" Margin="8,0,0,0" Foreground="{Binding Comparison, Converter={x:Static local:ComparisonColorConverter.Instance}}" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
 
                    <Button Grid.Row="2" Command="{Binding TransferCommand}" Content="開始轉移" Style="{StaticResource BtnPrimary}" Margin="0,16,0,0" IsEnabled="{Binding CanTransfer}"/>
                </Grid>
            </Border>
 
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}"/>
 
            <!-- Right: Report & Comparison Details -->
            <Border Grid.Column="4" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 上半部：詳細差異比對表 -->
                    <TextBlock Grid.Row="0" Text="🔍 參數差異比對 (選取清單項目檢視)" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveDiffDetails}" AutoGenerateColumns="False" IsReadOnly="True" Background="{StaticResource BgCard}" BorderThickness="0" GridLinesVisibility="None" RowHeaderWidth="0" Foreground="{StaticResource TextPrimary}">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1C2128"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2F363D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                        <Setter Property="Foreground" Value="#F25C54"/> <!-- 差異欄位亮紅色 -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="參數/屬性名稱" Binding="{Binding ParamName}" Width="1.2*"/>
                            <DataGridTextColumn Header="來源專案值" Binding="{Binding SourceValue}" Width="1.4*"/>
                            <DataGridTextColumn Header="目標專案值" Binding="{Binding TargetValue}" Width="1.4*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 分隔線 -->
                    <GridSplitter Grid.Row="2" Height="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}" Margin="0,12"/>

                    <!-- 下半部：原本的轉移報告 -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📋 轉移執行報告" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="1" Text="{Binding ReportText, Mode=OneWay}" Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}" BorderThickness="0" FontFamily="Consolas" IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="8"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
