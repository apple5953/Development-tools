<Window x:Class="DevelopmentTools.Modules.SheetTools.SheetDuplicator.SheetDuplicatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:DevelopmentTools.Modules.SheetTools.SheetDuplicator"
        xmlns:core="clr-namespace:DevelopmentTools.Core;assembly=DevelopmentTools.Addin"
        mc:Ignorable="d"
        Title="{Binding [SheetDuplicator_Title], Source={x:Static core:LanguageManager.Instance}}" Height="650" Width="1000"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeView Styling -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側主操作區 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [SheetDuplicator_Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CBA6F7" VerticalAlignment="Center"/>
                <Button Grid.Column="1" 
                        Content="{Binding [TileSys_Tutorial], Source={x:Static core:LanguageManager.Instance}}"
                        Command="{Binding OpenHelpCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Background="#F9E2AF"
                        Foreground="#1E1E2E"
                        Height="26"
                        Padding="10,0"
                        VerticalAlignment="Center"
                        ToolTip="{Binding [TileSys_TutorialDesc], Source={x:Static core:LanguageManager.Instance}}"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [SheetDuplicator_Prefix], Source={x:Static core:LanguageManager.Instance}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding SheetPrefix, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="{Binding [SheetDuplicator_Analyze], Source={x:Static core:LanguageManager.Instance}}" Command="{Binding AnalyzeCommand}" Width="60" Height="26" Style="{StaticResource PrimaryBtn}" Background="#89B4FA"/>
            </Grid>

            <GroupBox Grid.Row="2" Header="{Binding [SheetDuplicator_Structure], Source={x:Static core:LanguageManager.Instance}}" Foreground="#A6E3A1" BorderBrush="#45475A" Margin="0,0,0,15">
                <TreeView ItemsSource="{Binding AnalyzedSheets}" SelectedItemChanged="TreeView_SelectedItemChanged" Margin="5">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Views}">
                            <TextBlock Text="{Binding NodeName}" FontWeight="Bold" Foreground="#89DCEB" TextWrapping="Wrap" MaxWidth="300"/>
                            <HierarchicalDataTemplate.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding NodeName}" Foreground="#BAC2E0" TextWrapping="Wrap" MaxWidth="280"/>
                                        <TextBlock Text="{Binding ViewType, StringFormat=' ({0})'}" Foreground="#6C7086"/>
                                    </StackPanel>
                                </DataTemplate>
                            </HierarchicalDataTemplate.ItemTemplate>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="{Binding [SheetDuplicator_TargetLevels], Source={x:Static core:LanguageManager.Instance}}" Foreground="#F9E2AF" BorderBrush="#45475A" Margin="0,0,0,15" MaxHeight="150">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TargetLevels}" Margin="5">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" Width="100"/>
                                        <TextBlock Text="{Binding ElevationInfo}" Foreground="#6C7086"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{Binding [SheetDuplicator_Generate], Source={x:Static core:LanguageManager.Instance}}" Command="{Binding GenerateCommand}" Style="{StaticResource PrimaryBtn}" Background="#A6E3A1" Margin="0,0,10,0"/>
                <Button Grid.Column="1" Content="{Binding [Common_Close], Source={x:Static core:LanguageManager.Instance}}" Command="{Binding CloseCommand}" Style="{StaticResource PrimaryBtn}" Background="#45475A" Foreground="#CDD6F4" Width="100"/>
            </Grid>

            <TextBlock Grid.Row="5" Text="{Binding StatusText}" Foreground="#89B4FA" FontSize="11" TextWrapping="Wrap"/>
        </Grid>

        <!-- 分隔線 -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#313244"/>

        <!-- 右側預覽區 -->
        <GroupBox Grid.Column="2" Header="{Binding [SheetDuplicator_PreviewTitle], Source={x:Static core:LanguageManager.Instance}}" Foreground="#F38BA8" BorderBrush="#45475A">
            <Grid>
                <TextBlock Text="{Binding [SheetDuplicator_PreviewPrompt], Source={x:Static core:LanguageManager.Instance}}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6C7086">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSheetNode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <Viewbox Stretch="Uniform" Margin="10">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSheetNode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>
                    <Border BorderBrush="#BAC2E0" BorderThickness="2" Background="White" 
                            Width="{Binding SelectedSheetNode.SheetWidth}" Height="{Binding SelectedSheetNode.SheetHeight}">
                        <ItemsControl ItemsSource="{Binding SelectedSheetNode.Views}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding SelectedSheetNode.SheetWidth}" Height="{Binding SelectedSheetNode.SheetHeight}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                    <Setter Property="Canvas.Bottom" Value="{Binding Bottom}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}" Height="{Binding Height}" 
                                            BorderBrush="#1E1E2E" BorderThickness="1" Background="#A089B4FA" CornerRadius="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#A0F38BA8"/>
                                                        <Setter Property="BorderBrush" Value="#E64553"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Viewbox Stretch="Uniform" Margin="2">
                                            <TextBlock Text="{Binding ViewName}" Foreground="#1E1E2E" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                                        </Viewbox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Viewbox>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
