<Window x:Class="DevelopmentTools.Modules.SheetTools.QuickViewCreator.QuickViewCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速開圖與套樣板工具 v1.1" Height="620" Width="880"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 基礎按鈕樣式 -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要按鈕樣式 (紫色) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#CBA6F7"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#F5E0DC"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉選單樣式 -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>

        <!-- 小區塊邊框與標籤 -->
        <Style x:Key="SubPanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2,6,0,2"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid 樣式 -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush" Value="#313244"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#F5E0DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 樹狀圖樣式 -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="12" Height="12">
                                                    <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 0 8 Z" Fill="#585B70" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path.LayoutTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.LayoutTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#CDD6F4"/>
                                                        <Setter TargetName="Arrow" Property="LayoutTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter Grid.Row="1" x:Name="ItemsHost" Margin="15,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#F5E0DC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#181825"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 標題 -->
            <RowDefinition Height="Auto"/>
            <!-- 左右主要面板 -->
            <RowDefinition Height="*"/>
            <!-- 底部進度與執行 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="🗂️ 快速開圖與套樣板工具" FontSize="18" FontWeight="Bold" Foreground="#CBA6F7"/>
                <TextBlock Text="在左側專案瀏覽器勾選平面視圖，於右側配置套用樣板與命名後綴，並在預覽表中手動微調新視圖名稱與對應圖紙編號。" FontSize="11" Foreground="#89B4FA" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 2. 左右內容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左側：來源平面圖專案瀏覽器 (TreeView) -->
                <ColumnDefinition Width="2.8*"/>
                <!-- 間距 -->
                <ColumnDefinition Width="12"/>
                <!-- 右側：設定與預覽表格 -->
                <ColumnDefinition Width="5.2*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側：專案瀏覽器 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 搜尋 -->
                <TextBox Style="{StaticResource DarkTextBox}" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="搜尋視圖名稱..." Height="28" Margin="0,0,0,8" ToolTip="輸入平面圖名稱進行篩選"/>

                <!-- 快速工具 -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Button Content="☑️ 反選所有平面圖" Style="{StaticResource BaseBtn}" 
                            Command="{Binding ToggleSelectAllViewsCommand}" Height="22" FontSize="10" HorizontalAlignment="Left"/>
                    <TextBlock Text="▍ 1. 選擇來源平面圖" Style="{StaticResource SectionLabel}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"/>
                </Grid>

                <!-- 樹狀圖 -->
                <Border Grid.Row="2" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="8">
                    <TreeView x:Name="ViewTreeView" ItemsSource="{Binding TreeItems}"
                              Background="Transparent" BorderThickness="0" 
                              ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,1" ToolTipOpening="TreeViewItem_ToolTipOpening">
                                    <StackPanel.ToolTip>
                                        <ToolTip Background="#181825" BorderBrush="#313244" BorderThickness="1" Padding="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" FontSize="11" FontWeight="Bold" Margin="0,0,0,6" MaxWidth="250" TextWrapping="Wrap"/>
                                                <Image x:Name="PreviewImg" Width="250" Height="180" Stretch="Uniform" Visibility="Collapsed"/>
                                                <TextBlock x:Name="LoadingText" Text="正在載入預覽圖..." Foreground="#BAC2E0" FontSize="10"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </StackPanel.ToolTip>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <!-- 節點前綴 icon -->
                                    <TextBlock Text="📁 " Foreground="#F9E2AF" FontSize="12" 
                                               Visibility="{Binding IsGroup, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="📄 " Foreground="#A6E3A1" FontSize="12" 
                                               Visibility="{Binding IsView, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>

            <!-- 右側：設定與即時預覽 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!-- 2.1 樣板與命名後綴設定 -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                    <!-- 2.2 預覽與微調表格 -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 2.1 樣板選擇標籤 -->
                <TextBlock Grid.Row="0" Text="▍ 2. 選擇視圖樣板與命名後綴" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>

                <!-- 樣板設定表格 -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Templates}" Style="{StaticResource DarkDataGrid}" Margin="0,0,0,8">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- 勾選狀態 -->
                        <DataGridTemplateColumn Width="38">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- 樣板名稱 -->
                        <DataGridTextColumn Header="視圖樣板名稱" Binding="{Binding Name}" Width="1.5*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 命名後綴 -->
                        <DataGridTemplateColumn Header="命名後綴 (可雙擊修改)" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource DarkTextBox}" Height="20" Padding="4,0" Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 2.2 即時預覽標籤 -->
                <TextBlock Grid.Row="2" Text="▍ 3. 即時開圖與更名預覽 (雙擊目標欄位可進行客製化微調)" Style="{StaticResource SectionLabel}" Margin="0,4,0,4"/>

                <!-- 即時預覽與微調表格 -->
                <DataGrid Grid.Row="3" ItemsSource="{Binding PreviewItems}" Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- 建立圖紙 -->
                        <DataGridTemplateColumn Width="45" Header="圖紙">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding CreateSheet, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- 來源平面圖 -->
                        <DataGridTextColumn Header="來源視圖" Binding="{Binding SourceViewName}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 目標樣板 -->
                        <DataGridTextColumn Header="套用樣板" Binding="{Binding TemplateName}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 新視圖名稱 (可編輯) -->
                        <DataGridTextColumn Header="新視圖名稱 (可編輯)" Binding="{Binding TargetViewName, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" IsReadOnly="False">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="CaretBrush" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 圖紙編號 (可編輯) -->
                        <DataGridTextColumn Header="圖紙編號" Binding="{Binding SheetNumber, UpdateSourceTrigger=PropertyChanged}" Width="75" IsReadOnly="False">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="CaretBrush" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#F5E0DC"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- 3. 底部進度與執行 -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 複製模式 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="複製模式：" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                <ComboBox Style="{StaticResource DarkComboBox}" Width="150" SelectedIndex="{Binding DuplicateMode}">
                    <ComboBoxItem Content="僅複製結構 (Duplicate)"/>
                    <ComboBoxItem Content="複製詳圖 (With Detailing)"/>
                    <ComboBoxItem Content="建立相依視圖 (As Dependent)"/>
                </ComboBox>
            </StackPanel>

            <!-- 全域建立圖紙切換 -->
            <CheckBox Grid.Column="1" IsChecked="{Binding CreateSheets}" Content="一鍵同步建立圖紙" 
                      Foreground="#CDD6F4" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"
                      ToolTip="勾選後，會自動將下方預覽列表的所有項目切換為同步建立圖紙"/>

            <!-- 狀態提示 -->
            <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="#FAB387" 
                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>

            <!-- 按鈕 -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="🚀 批次一鍵開圖" Style="{StaticResource PrimaryBtn}" 
                        Command="{Binding CreateViewsCommand}" Width="130" Height="30" Margin="0,0,10,0"/>
                <Button Content="取消" Style="{StaticResource BaseBtn}" 
                        Command="{Binding CancelCommand}" Width="70" Height="30"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
