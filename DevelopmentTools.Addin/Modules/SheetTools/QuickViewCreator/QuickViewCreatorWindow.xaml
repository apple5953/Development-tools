<Window x:Class="DevelopmentTools.Modules.SheetTools.QuickViewCreator.QuickViewCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:DevelopmentTools.Core"
        Title="{Binding [QuickView_Title], Source={x:Static core:LanguageManager.Instance}}" MinHeight="550" MinWidth="950" Height="650" Width="1000"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 基礎按鈕樣式 -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要按鈕樣式 (紫色) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#CBA6F7"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 危險按鈕樣式 (紅色) -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 綠色按鈕 -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#F5E0DC"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉選單樣式 -->
        

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2,6,0,6"/>
        </Style>

        <!-- DataGrid 樣式 -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush" Value="#313244"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#F5E0DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 樹狀圖樣式 -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="12" Height="12">
                                                    <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 0 8 Z" Fill="#585B70" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path.LayoutTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.LayoutTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#CDD6F4"/>
                                                        <Setter TargetName="Arrow" Property="LayoutTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter Grid.Row="1" x:Name="ItemsHost" Margin="15,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#F5E0DC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#181825"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 標題 -->
            <RowDefinition Height="Auto"/>
            <!-- 三個主要面板 -->
            <RowDefinition Height="*"/>
            <!-- 底部進度與執行 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding [QuickView_Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#CBA6F7"/>
                <TextBlock Text="{Binding [QuickView_SubTitle], Source={x:Static core:LanguageManager.Instance}}" FontSize="11" Foreground="#89B4FA" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" 
                    Content="{Binding [TileSys_Tutorial], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource BaseBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="10,0"
                    VerticalAlignment="Center"
                    ToolTip="{Binding [TileSys_TutorialDesc], Source={x:Static core:LanguageManager.Instance}}"/>
        </Grid>

        <!-- 2. 三欄內容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左側：專案瀏覽器 -->
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="8"/>
                <!-- 中間：加入購物車控制台 -->
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="8"/>
                <!-- 右側：待執行清單 (購物車) -->
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <!-- ▍ 區塊 1. 左側：專案瀏覽器 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding [QuickView_Step1], Source={x:Static core:LanguageManager.Instance}}" FontWeight="Bold" FontSize="14" Foreground="#89B4FA" Margin="0,0,0,10"/>
                <TextBox Style="{StaticResource DarkTextBox}" Height="28" Margin="0,0,0,10" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Button Style="{StaticResource BaseBtn}" 
                            Command="{Binding ToggleSelectAllViewsCommand}" Height="22" FontSize="10" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding [QuickView_ToggleSelectAll], Source={x:Static core:LanguageManager.Instance}}" />
                    </Button>
                </Grid>

                <Border Grid.Row="2" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="8">
                    <TreeView x:Name="ViewTreeView" ItemsSource="{Binding TreeItems}"
                              Background="Transparent" BorderThickness="0" 
                              ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" ToolTipOpening="TreeViewItem_ToolTipOpening">
                                    <StackPanel.ToolTip>
                                        <ToolTip Background="#181825" BorderBrush="#313244" BorderThickness="1" Padding="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" FontSize="11" FontWeight="Bold" Margin="0,0,0,6" MaxWidth="250" TextWrapping="Wrap"/>
                                                <Image x:Name="PreviewImg" Width="250" Height="180" Stretch="Uniform" Visibility="Collapsed"/>
                                                <TextBlock x:Name="LoadingText" Text="{Binding [QuickView_LoadingPreview], Source={x:Static core:LanguageManager.Instance}}" Foreground="#BAC2E0" FontSize="10"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </StackPanel.ToolTip>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="📁 " Foreground="#F9E2AF" FontSize="12" 
                                               Visibility="{Binding IsGroup, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="📄 " Foreground="#A6E3A1" FontSize="12" 
                                               Visibility="{Binding IsView, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>

            <!-- 分隔線 1 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#45475A" Cursor="SizeWE" Margin="0,10"/>

            <!-- ▍ 區塊 2. 中間：設定並加入 -->
            <Border Grid.Column="2" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="{Binding [QuickView_Step2], Source={x:Static core:LanguageManager.Instance}}" FontWeight="Bold" FontSize="14" Foreground="#F9E2AF" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="{Binding [QuickView_SelectTemplate], Source={x:Static core:LanguageManager.Instance}}" Margin="0,0,0,4" Foreground="#A6ADC8"/>
                    <ComboBox  ItemsSource="{Binding TemplateOptions}" 
                              SelectedItem="{Binding SelectedTemplate}"
                              DisplayMemberPath="Name"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding [QuickView_Count], Source={x:Static core:LanguageManager.Instance}}" Margin="0,0,0,4" Foreground="#A6ADC8"/>
                    <TextBox Text="{Binding InputCopyCount, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                             Style="{StaticResource DarkTextBox}" Height="30" FontSize="14" FontWeight="Bold" Margin="0,0,0,24"/>

                    <Button Style="{StaticResource SuccessBtn}" Height="36" Margin="0,20,0,0" Command="{Binding AddToListCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding [QuickView_AddToList], Source={x:Static core:LanguageManager.Instance}}" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 分隔線 2 -->
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#45475A" Cursor="SizeWE" Margin="0,10"/>

            <!-- ▍ 區塊 3. 右側：待執行清單 -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="{Binding [QuickView_Step3], Source={x:Static core:LanguageManager.Instance}}" FontWeight="Bold" FontSize="14" Foreground="#A6E3A1" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BaseBtn}" Background="#313244" Margin="0,0,10,0" Command="{Binding RemoveSelectedCommand}">
                            <TextBlock Text="{Binding [QuickView_RemoveSelected], Source={x:Static core:LanguageManager.Instance}}"/>
                        </Button>
                        <Button Style="{StaticResource DangerBtn}" Height="28" Command="{Binding ClearListCommand}">
                            <TextBlock Text="{Binding [QuickView_ClearAll], Source={x:Static core:LanguageManager.Instance}}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewItems}" SelectedItem="{Binding SelectedPreviewItem}" Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- 建立圖紙 CheckBox -->
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{Binding [QuickView_ColCreateSheet], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding CreateSheet, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- 來源平面圖 -->
                        <DataGridTextColumn Binding="{Binding SourceViewName}" Width="1.2*" IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [QuickView_ColSource], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 目標樣板 -->
                        <DataGridTextColumn Binding="{Binding TemplateName}" Width="1.5*" IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [QuickView_ColTemplate], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 新視圖名稱 (可編輯) -->
                        <DataGridTextColumn Binding="{Binding TargetViewName, UpdateSourceTrigger=PropertyChanged}" Width="2*" IsReadOnly="False">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [QuickView_ColTargetName], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="CaretBrush" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!-- 圖紙編號 (可編輯) -->
                        <DataGridTextColumn Binding="{Binding SheetNumber, UpdateSourceTrigger=PropertyChanged}" Width="130" IsReadOnly="False">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [QuickView_ColSheetNum], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="CaretBrush" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="#F5E0DC"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- 3. 底部進度與執行 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 狀態提示 -->
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="#FAB387" 
                       VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <!-- 按鈕 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryBtn}" 
                        Command="{Binding CreateViewsCommand}" Width="140" Height="34" Margin="0,0,10,0">
                    <TextBlock Text="{Binding [QuickView_ExecBtn], Source={x:Static core:LanguageManager.Instance}}"/>
                </Button>
                <Button Style="{StaticResource BaseBtn}" 
                        Command="{Binding CancelCommand}" Width="70" Height="34">
                    <TextBlock Text="{Binding [Common_Close], Source={x:Static core:LanguageManager.Instance}}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
