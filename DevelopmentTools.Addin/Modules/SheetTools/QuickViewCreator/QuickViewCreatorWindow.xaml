<Window x:Class="DevelopmentTools.Modules.SheetTools.QuickViewCreator.QuickViewCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速開圖與套樣板工具 v1.0" Height="580" Width="800"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <!-- 系統內建轉換器 -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 基礎按鈕樣式 -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要按鈕樣式 (紫色) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#CBA6F7"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#F5E0DC"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉選單樣式 -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>

        <!-- 小區塊邊框與標籤 -->
        <Style x:Key="SubPanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2,10,0,2"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid 樣式 -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush" Value="#313244"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#F5E0DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- 標題 -->
            <RowDefinition Height="Auto"/>
            <!-- 左右主要面板 -->
            <RowDefinition Height="*"/>
            <!-- 底部進度與執行 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🗂️ 快速開圖與套樣板工具" FontSize="16" FontWeight="Bold" Foreground="#CBA6F7"/>
                <TextBlock Text="從現有平面視圖，批次複製命名並套用不同樣板，一鍵自動完成圖說建置" FontSize="10" Foreground="#89B4FA" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 2. 左右內容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左側：來源平面圖清單 -->
                <ColumnDefinition Width="*"/>
                <!-- 間距 -->
                <ColumnDefinition Width="12"/>
                <!-- 右側：視圖樣板與設定 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側：平面圖清單 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 搜尋與過濾 -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Style="{StaticResource DarkTextBox}" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="輸入平面圖名稱進行篩選"/>
                </Grid>

                <!-- 快速工具 -->
                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Button Content="☑️ 反選所有平面圖" Style="{StaticResource BaseBtn}" 
                            Command="{Binding ToggleSelectAllViewsCommand}" Height="22" FontSize="10" HorizontalAlignment="Left"/>
                    <TextBlock Text="▍ 1. 選擇來源平面圖" Style="{StaticResource SectionLabel}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0"/>
                </Grid>

                <!-- 平面圖 DataGrid -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredViews}"
                          Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- 勾選 -->
                        <DataGridTemplateColumn Width="38">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 類型 -->
                        <DataGridTextColumn Header="視圖類型" Binding="{Binding ViewTypeStr}" Width="90" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#89B4FA"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 視圖名稱 -->
                        <DataGridTextColumn Header="視圖名稱" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- 右側：視圖樣板與設定 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="▍ 2. 選擇要套用的視圖樣板 (多選)" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>

                <!-- 樣板 DataGrid -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Templates}"
                          Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="38">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="視圖樣板名稱" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="2" Text="▍ 3. 開圖與複製設定" Style="{StaticResource SectionLabel}"/>

                <!-- 設定邊框 -->
                <Border Grid.Row="3" Style="{StaticResource SubPanelBorder}" VerticalAlignment="Stretch">
                    <StackPanel>
                        <!-- 複製模式 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="複製模式" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" 
                                      SelectedIndex="{Binding DuplicateMode}">
                                <ComboBoxItem Content="僅複製結構 (Duplicate)"/>
                                <ComboBoxItem Content="複製詳圖 (With Detailing)"/>
                                <ComboBoxItem Content="建立相依視圖 (As Dependent)"/>
                            </ComboBox>
                        </Grid>

                        <!-- 自動建立圖紙 -->
                        <Grid Margin="0,6,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox IsChecked="{Binding CreateSheets}" Content="同步為新建視圖自動建立圖紙並置入" 
                                      Foreground="#CDD6F4" FontSize="11"
                                      ToolTip="勾選後，系統會自動使用專案圖框建立圖紙，並把新視圖放到圖紙中央，免手動排版。"/>
                        </Grid>

                        <TextBlock Text="* 新視圖的命名預設為：[原平面圖名稱] - [樣板名稱]&#x0a;* 若名稱重複，系統會自動在後方加上遞增後綴 (_1, _2)，不報錯。" 
                                   Foreground="#6C7086" FontSize="10" LineHeight="14" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 3. 底部進度與執行 -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 狀態提示 -->
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="#FAB387" 
                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>

            <!-- 按鈕 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="🚀 批次一鍵開圖" Style="{StaticResource PrimaryBtn}" 
                        Command="{Binding CreateViewsCommand}" Width="150" Height="30" Margin="0,0,10,0"/>
                <Button Content="取消" Style="{StaticResource BaseBtn}" 
                        Command="{Binding CancelCommand}" Width="80" Height="30"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
