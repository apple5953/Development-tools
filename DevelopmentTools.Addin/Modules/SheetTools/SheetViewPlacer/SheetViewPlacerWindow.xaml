<Window x:Class="DevelopmentTools.Modules.SheetTools.SheetViewPlacer.SheetViewPlacerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DevelopmentTools.Modules.SheetTools.SheetViewPlacer"
        xmlns:core="clr-namespace:DevelopmentTools.Core"
        mc:Ignorable="d"
        Title="{Binding [SheetPlacer_Title], Source={x:Static core:LanguageManager.Instance}}" Height="650" Width="880"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Microsoft JhengHei"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- 基礎按鈕樣式 -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要按鈕樣式 (藍色) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 套用按鈕樣式 (綠色) -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <!-- 危險按鈕樣式 (紅色) -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#F5E0DC"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#CBA6F7"/>
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉選單樣式 -->
        <!-- 樹狀圖節點樣式 -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Padding" Value="2,3"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="MouseMove" Handler="TreeViewItem_MouseMove"/>
            <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver"/>
            <EventSetter Event="Drop" Handler="TreeViewItem_Drop"/>
            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 展開折疊箭頭 -->
                                    <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="12" Height="12">
                                                    <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 0 8 Z" Fill="#585B70" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path.LayoutTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.LayoutTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#CDD6F4"/>
                                                        <Setter TargetName="Arrow" Property="LayoutTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter Grid.Row="1" x:Name="ItemsHost" Margin="15,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#F5E0DC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#181825"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented Tab Button Style -->
        <Style x:Key="SegmentedTabBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#313244" BorderBrush="#45475A" BorderThickness="1" CornerRadius="4" Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#89B4FA"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 0. 標題與說明 -->
            <RowDefinition Height="Auto"/>
            <!-- 1. 搜尋過濾 & 控制列 -->
            <RowDefinition Height="Auto"/>
            <!-- 2. 主排版區 (樹狀圖拖曳 + 設定面版) -->
            <RowDefinition Height="*"/>
            <!-- 3. 底部動作列 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 0. 標題與說明 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding [SheetPlacer_Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="18" FontWeight="Bold" Foreground="#F5E0DC"/>
                <TextBlock Text="{Binding [SheetPlacer_SubTitle], Source={x:Static core:LanguageManager.Instance}}" 
                            FontSize="11" Foreground="#A6ADC8" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Content="{Binding [TileSys_Tutorial], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource BaseBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="10,0"
                    VerticalAlignment="Center"
                    ToolTip="{Binding [TileSys_TutorialDesc], Source={x:Static core:LanguageManager.Instance}}"/>
        </Grid>

        <!-- 1. 搜尋過濾 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Here ToolTip is a better alternative to Tag for translation bindings -->
            <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Height="28" ToolTip="{Binding [SheetPlacer_SearchPrompt], Source={x:Static core:LanguageManager.Instance}}"
                     Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,8,0"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource BaseBtn}" Click="RefreshBtn_Click" Margin="0,0,6,0">
                    <TextBlock Text="{Binding [SheetPlacer_RefreshBtn], Source={x:Static core:LanguageManager.Instance}}" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. 主排版區 -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: 樹狀圖排版區 (TreeView) -->
            <Border Grid.Column="0" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="8">
                <TreeView x:Name="SheetTreeView" ItemsSource="{Binding TreeItems}" AllowDrop="True"
                          Background="Transparent" BorderThickness="0" 
                          ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          DragOver="SheetTreeView_DragOver" Drop="SheetTreeView_Drop"
                          KeyDown="SheetTreeView_KeyDown"
                          SelectedItemChanged="SheetTreeView_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2,1" ToolTipOpening="TreeViewItem_ToolTipOpening">
                                <StackPanel.ToolTip>
                                    <ToolTip Background="#181825" BorderBrush="#313244" BorderThickness="1" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" FontSize="11" FontWeight="Bold" Margin="0,0,0,6" MaxWidth="250" TextWrapping="Wrap"/>
                                            <Image x:Name="PreviewImg" Width="250" Height="180" Stretch="Uniform" Visibility="Collapsed"/>
                                            <TextBlock x:Name="LoadingText" Text="{Binding [SheetPlacer_LoadingPreview], Source={x:Static core:LanguageManager.Instance}}" Foreground="#BAC2E0" FontSize="10"/>
                                        </StackPanel>
                                    </ToolTip>
                                </StackPanel.ToolTip>
                                <!-- 節點前綴 icon 或字型 -->
                                <TextBlock Text="📁 " Foreground="#F9E2AF" FontSize="12" 
                                           Visibility="{Binding IsGroup, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="📄 " Foreground="#A6E3A1" FontSize="12" 
                                           Visibility="{Binding IsView, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <Grid VerticalAlignment="Center">
                                    <!-- 唯讀文字顯示模式 -->
                                    <TextBlock x:Name="NameText" Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                    <!-- 編輯文字輸入框模式 -->
                                    <TextBox x:Name="EditBox" Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="12" VerticalAlignment="Center" MinWidth="150" Height="22"
                                             Background="#313244" Foreground="#CDD6F4" CaretBrush="#F5E0DC"
                                             BorderBrush="#89B4FA" BorderThickness="1" Padding="2,0" Margin="-2,-1,0,-1"
                                             Visibility="Collapsed" LostFocus="RenameTextBox_LostFocus" KeyDown="RenameTextBox_KeyDown" IsVisibleChanged="RenameTextBox_IsVisibleChanged"/>
                                </Grid>
                            </StackPanel>
                            <HierarchicalDataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="EditBox" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <!-- 分割條 -->
            <GridSplitter Grid.Column="1" Width="2" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- 右側: 設定面板與動作 -->
            <Grid Grid.Column="2" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding [SheetPlacer_SettingsTitle], Source={x:Static core:LanguageManager.Instance}}" FontWeight="Bold" Foreground="#89B4FA" Margin="0,0,0,10" FontSize="12"/>

                        <!-- 預設圖框 -->
                        <TextBlock Text="{Binding [SheetPlacer_DefaultTitleBlock], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" Foreground="#A6ADC8" Margin="0,4,0,2"/>
                        <ComboBox   
                                  ItemsSource="{Binding TitleBlocks}"
                                  SelectedItem="{Binding SelectedTitleBlock}"
                                  DisplayMemberPath="Name" Margin="0,0,0,10"/>

                        <!-- 預設視埠類型 -->
                        <TextBlock Text="{Binding [SheetPlacer_DefaultViewport], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" Foreground="#A6ADC8" Margin="0,4,0,2"/>
                        <ComboBox   
                                  ItemsSource="{Binding ViewportTypes}"
                                  SelectedItem="{Binding SelectedViewportType}"
                                  DisplayMemberPath="Name" Margin="0,0,0,14"/>

                        <!-- 操作按鈕 -->
                        <Button Style="{StaticResource PrimaryBtn}" 
                                Click="NewSheetBtn_Click" Height="30" Margin="0,0,0,8">
                            <TextBlock Text="{Binding [SheetPlacer_NewSheetBtn], Source={x:Static core:LanguageManager.Instance}}" />
                        </Button>
                        
                        <Button Style="{StaticResource DangerBtn}" 
                                Click="RemoveViewBtn_Click" Height="30">
                            <TextBlock Text="{Binding [SheetPlacer_RemoveViewBtn], Source={x:Static core:LanguageManager.Instance}}" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- 操作教學面板 -->
                <Border Grid.Row="1" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="12"
                        Visibility="{Binding ShowInstructions, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding [SheetPlacer_InstructTitle], Source={x:Static core:LanguageManager.Instance}}" FontWeight="Bold" Foreground="#A6E3A1" Margin="0,0,0,8" FontSize="12"/>
                            
                            <TextBlock Text="{Binding [SheetPlacer_Instruct1Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="11" Foreground="#CDD6F4" FontWeight="Bold" Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding [SheetPlacer_Instruct1Text], Source={x:Static core:LanguageManager.Instance}}" 
                                       FontSize="10" Foreground="#A6ADC8" LineHeight="15" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding [SheetPlacer_Instruct2Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="11" Foreground="#CDD6F4" FontWeight="Bold" Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding [SheetPlacer_Instruct2Text], Source={x:Static core:LanguageManager.Instance}}" 
                                       FontSize="10" Foreground="#A6ADC8" LineHeight="15" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding [SheetPlacer_Instruct3Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="11" Foreground="#CDD6F4" FontWeight="Bold" Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding [SheetPlacer_Instruct3Text], Source={x:Static core:LanguageManager.Instance}}" 
                                       FontSize="10" Foreground="#A6ADC8" LineHeight="15" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- 圖紙內視圖位置調整與對齊排版面板 -->
                <Border Grid.Row="1" Background="#181825" BorderBrush="#313244" BorderThickness="1" CornerRadius="6" Padding="12"
                        Visibility="{Binding HasSelectedSheet, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 標題與分頁按鈕 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 視圖列表或畫布 -->
                            <RowDefinition Height="*"/>
                            <!-- 控制選項 -->
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 標題 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="{Binding [SheetPlacer_TweakTitle], Source={x:Static core:LanguageManager.Instance}}" FontWeight="Bold" Foreground="#89B4FA" FontSize="12"/>
                            <TextBlock Text="{Binding SelectedSheetNode.Name}" Foreground="#BAC2E0" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,8"/>
                            
                            <!-- Segmented Tab 切換控制項 -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="TabVisualRadio" Content="{Binding [SheetPlacer_TabVisual], Source={x:Static core:LanguageManager.Instance}}" IsChecked="True" Style="{StaticResource SegmentedTabBtn}" Margin="0,0,3,0"/>
                                <RadioButton x:Name="TabNumericRadio" Grid.Column="1" Content="{Binding [SheetPlacer_TabNumeric], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SegmentedTabBtn}" Margin="3,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- 視圖列表 (對齊與微調模式) -->
                        <ListBox x:Name="PlacedViewsListBox" Grid.Row="1" ItemsSource="{Binding PlacedViews}" SelectionMode="Extended"
                                 Background="#1E1E2E" BorderBrush="#313244" BorderThickness="1" Margin="0,0,0,8"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="PlacedViewsListBox_SelectionChanged"
                                 Visibility="{Binding IsChecked, ElementName=TabNumericRadio, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Foreground="#BAC2E0" FontSize="10" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="({0:F0}, {1:F0}) mm">
                                                    <Binding Path="XMm"/>
                                                    <Binding Path="YMm"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- 可視化畫布預覽區 (可視化畫布模式) -->
                        <Viewbox Grid.Row="1" Grid.RowSpan="2" Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 Visibility="{Binding IsChecked, ElementName=TabVisualRadio, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Width="{Binding SheetWidthMm}" Height="{Binding SheetHeightMm}" 
                                    Background="#11111B" BorderBrush="#45475A" BorderThickness="2" CornerRadius="4">
                                <ItemsControl x:Name="PlacedViewsItemsControl" ItemsSource="{Binding PlacedViews}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Background="Transparent" IsItemsHost="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding CanvasX}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding CanvasY}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding WidthMm}" Height="{Binding HeightMm}"
                                                    Background="#2689B4FA" BorderBrush="#89B4FA" BorderThickness="1.5" CornerRadius="3"
                                                    Cursor="SizeAll"
                                                    MouseLeftButtonDown="CanvasItem_MouseLeftButtonDown"
                                                    MouseMove="CanvasItem_MouseMove"
                                                    MouseLeftButtonUp="CanvasItem_MouseLeftButtonUp">
                                                <Grid>
                                                    <TextBlock Text="{Binding Name}" Foreground="#CDD6F4" FontSize="9"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="4"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Viewbox>

                        <!-- 下方控制項 (對齊與微調模式) -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Height="220"
                                      Visibility="{Binding IsChecked, ElementName=TabNumericRadio, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <!-- 1. 座標手動編輯與微調 -->
                                <Grid Margin="0,4,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="X (mm):" FontSize="10" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                                    <TextBox x:Name="PosXTextBox" Grid.Column="1" Style="{StaticResource DarkTextBox}" Width="65" Margin="4,0,12,0"
                                             LostFocus="PosXTextBox_LostFocus" KeyDown="PosXTextBox_KeyDown"/>
                                    
                                    <TextBlock Grid.Column="2" Text="Y (mm):" FontSize="10" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                                    <TextBox x:Name="PosYTextBox" Grid.Column="3" Style="{StaticResource DarkTextBox}" Width="65" Margin="4,0,0,0"
                                             LostFocus="PosYTextBox_LostFocus" KeyDown="PosYTextBox_KeyDown"/>
                                </Grid>

                                <!-- 2. 方向微調與間距 -->
                                <TextBlock Text="{Binding [SheetPlacer_TweakStepTitle], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" FontWeight="Bold" Foreground="#A6E3A1" Margin="0,4,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 方向鍵盤 (3x3 Grid) -->
                                    <Grid Width="90" Height="90" HorizontalAlignment="Left">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Row="0" Grid.Column="1" Content="▲" Style="{StaticResource BaseBtn}" Padding="0" Click="TweakUpBtn_Click"/>
                                        <Button Grid.Row="1" Grid.Column="0" Content="◀" Style="{StaticResource BaseBtn}" Padding="0" Click="TweakLeftBtn_Click"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="▶" Style="{StaticResource BaseBtn}" Padding="0" Click="TweakRightBtn_Click"/>
                                        <Button Grid.Row="2" Grid.Column="1" Content="▼" Style="{StaticResource BaseBtn}" Padding="0" Click="TweakDownBtn_Click"/>
                                    </Grid>
                                    
                                    <!-- 步長設定 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding [SheetPlacer_TweakStepLabel], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="StepSizeTextBox" Style="{StaticResource DarkTextBox}" Text="10" Width="80" Margin="0,4,0,0" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 3. 對齊工具 -->
                                <TextBlock Text="{Binding [SheetPlacer_AlignTitle], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" FontWeight="Bold" Foreground="#CBA6F7" Margin="0,4,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource BaseBtn}" Margin="0,0,4,4" Click="AlignLeftBtn_Click">
                                        <TextBlock Text="{Binding [SheetPlacer_AlignLeft], Source={x:Static core:LanguageManager.Instance}}" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource BaseBtn}" Margin="0,0,4,4" Click="AlignVCenterBtn_Click">
                                        <TextBlock Text="{Binding [SheetPlacer_AlignVCenter], Source={x:Static core:LanguageManager.Instance}}" />
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource BaseBtn}" Margin="0,0,0,4" Click="AlignRightBtn_Click">
                                        <TextBlock Text="{Binding [SheetPlacer_AlignRight], Source={x:Static core:LanguageManager.Instance}}" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource BaseBtn}" Margin="0,0,4,0" Click="AlignTopBtn_Click">
                                        <TextBlock Text="{Binding [SheetPlacer_AlignTop], Source={x:Static core:LanguageManager.Instance}}" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource BaseBtn}" Margin="0,0,4,0" Click="AlignHCenterBtn_Click">
                                        <TextBlock Text="{Binding [SheetPlacer_AlignHCenter], Source={x:Static core:LanguageManager.Instance}}" />
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource BaseBtn}" Margin="0,0,0,0" Click="AlignBottomBtn_Click">
                                        <TextBlock Text="{Binding [SheetPlacer_AlignBottom], Source={x:Static core:LanguageManager.Instance}}" />
                                    </Button>
                                </Grid>

                                <!-- 4. 網格排列 -->
                                <TextBlock Text="{Binding [SheetPlacer_GridTitle], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" FontWeight="Bold" Foreground="#F9E2AF" Margin="0,4,0,4"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,4,0">
                                        <TextBlock Text="{Binding [SheetPlacer_GridRows], Source={x:Static core:LanguageManager.Instance}}" FontSize="9" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="GridRowsTextBox" Style="{StaticResource DarkTextBox}" Text="2" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding [SheetPlacer_GridCols], Source={x:Static core:LanguageManager.Instance}}" FontSize="9" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="GridColsTextBox" Style="{StaticResource DarkTextBox}" Text="2" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding [SheetPlacer_GridGapX], Source={x:Static core:LanguageManager.Instance}}" FontSize="9" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="GridGapXTextBox" Style="{StaticResource DarkTextBox}" Text="150" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="{Binding [SheetPlacer_GridGapY], Source={x:Static core:LanguageManager.Instance}}" FontSize="9" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="GridGapYTextBox" Style="{StaticResource DarkTextBox}" Text="150" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,4,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,4,0">
                                        <TextBlock Text="{Binding [SheetPlacer_GridStartX], Source={x:Static core:LanguageManager.Instance}}" FontSize="9" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="GridStartXTextBox" Style="{StaticResource DarkTextBox}" Text="0" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding [SheetPlacer_GridStartY], Source={x:Static core:LanguageManager.Instance}}" FontSize="9" Foreground="#A6ADC8"/>
                                        <TextBox x:Name="GridStartYTextBox" Style="{StaticResource DarkTextBox}" Text="0" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Button Style="{StaticResource SuccessBtn}" Click="GridLayoutBtn_Click" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding [SheetPlacer_GridApplyBtn], Source={x:Static core:LanguageManager.Instance}}" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 3. 底部動作列 -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Here I didn't translate StatusText entirely because it seems to be updated dynamically in code-behind, but I translated the initial "狀態：就緒" -->
            <TextBlock x:Name="StatusText" Text="{Binding [SheetPlacer_StatusReady], Source={x:Static core:LanguageManager.Instance}}" Foreground="#A6ADC8" FontSize="11" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource BaseBtn}" Click="CloseBtn_Click" Width="80" Height="28">
                <TextBlock Text="{Binding [SheetPlacer_CloseBtn], Source={x:Static core:LanguageManager.Instance}}" />
            </Button>
        </Grid>
    </Grid>
</Window>
