<Window x:Class="DevelopmentTools.Modules.SheetTools.BatchSheetRenamer.BatchSheetRenamerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="圖紙批次更名工具 v1.0" Height="620" Width="880"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- 基礎按鈕樣式 -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要按鈕樣式 (藍色) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 套用按鈕樣式 (綠色) -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#F5E0DC"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#CBA6F7"/>
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉選單樣式 -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>

        <!-- 工具箱小面板樣式 -->
        <Style x:Key="ToolPanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 工具面板小標題 -->
        <Style x:Key="ToolHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5C2E7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 欄位標籤樣式 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <!-- DataGrid 樣式 -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush" Value="#313244"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <!-- DataGridCell 樣式 -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#F5E0DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- 標題與搜尋 -->
            <RowDefinition Height="Auto"/>
            <!-- 主要內容 (左邊工具箱，右邊清單) -->
            <RowDefinition Height="*"/>
            <!-- 底部按鈕區 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 標題與搜尋過濾 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="🗂️ 圖紙批次更名工具" FontSize="16" FontWeight="Bold" Foreground="#CBA6F7"/>
                <TextBlock Text="批次修改、重排編號與更名，一鍵套用，自動防範 Revit 唯一性衝突" FontSize="10" Foreground="#89B4FA" Margin="0,2,0,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔍 關鍵字過濾：" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                <TextBox Width="200" Style="{StaticResource DarkTextBox}" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="輸入圖紙編號或圖紙名稱即時搜尋過濾清單"/>
            </StackPanel>
        </Grid>

        <!-- 2. 主要內容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左側工具箱 -->
                <ColumnDefinition Width="260"/>
                <!-- 間距 -->
                <ColumnDefinition Width="10"/>
                <!-- 右側 DataGrid 清單 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側工具箱 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,2,0">
                    
                    <!-- 面板：尋找與取代 -->
                    <Border Style="{StaticResource ToolPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="🔍 尋找與取代" Style="{StaticResource ToolHeader}"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="套用目標" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" 
                                          SelectedIndex="{Binding FindReplaceTarget}">
                                    <ComboBoxItem Content="圖紙編號"/>
                                    <ComboBoxItem Content="圖紙名稱"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="尋找文字" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="取代為" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Button Content="套用取代" Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding ApplyFindReplaceCommand}" Margin="0,6,0,0"
                                    ToolTip="將「尋找文字」取代為「取代為」。若無勾選任何圖紙，將套用至目前顯示的所有圖紙。"/>
                        </StackPanel>
                    </Border>

                    <!-- 面板：加首綴與尾綴 -->
                    <Border Style="{StaticResource ToolPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="➕ 新增前綴 / 後綴" Style="{StaticResource ToolHeader}"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="套用目標" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" 
                                          SelectedIndex="{Binding PrefixSuffixTarget}">
                                    <ComboBoxItem Content="圖紙編號"/>
                                    <ComboBoxItem Content="圖紙名稱"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="前綴字元" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding PrefixText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="後綴字元" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding SuffixText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Button Content="套用首尾綴" Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding ApplyPrefixSuffixCommand}" Margin="0,6,0,0"
                                    ToolTip="在目標的前面或後面添加字串。若無勾選，將套用至目前顯示的所有圖紙。"/>
                        </StackPanel>
                    </Border>

                    <!-- 面板：自動序號重排 -->
                    <Border Style="{StaticResource ToolPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="🔢 自動編號重排" Style="{StaticResource ToolHeader}"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="起始編號" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" 
                                         Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="例如：A-101"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="編號增量" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" 
                                         Text="{Binding Increment, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="編號遞增間距，例如：1"/>
                            </Grid>
                            <Button Content="執行自動重排" Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding ApplyAutoReindexCommand}" Margin="0,6,0,0"
                                    ToolTip="從起始編號開始遞增重排。若有勾選則重排勾選的圖紙；若無勾選則依清單順序重排目前所有圖紙。"/>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- 右側 DataGrid 清單 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- DataGrid 上方工具列 (全選等) -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="☑️ 反選所有圖紙" Style="{StaticResource BaseBtn}" 
                                Command="{Binding ToggleSelectAllCommand}" Height="22" FontSize="10"/>
                    </StackPanel>
                    <TextBlock Text="* 提示：按兩下欄位格子即可直接編輯" 
                               Foreground="#A6ADC8" FontSize="10" FontStyle="Italic"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredSheets}"
                          Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- 勾選框 -->
                        <DataGridTemplateColumn Width="38">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 修改標誌 -->
                        <DataGridTemplateColumn Header="異動" Width="45">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="✏️" Foreground="#FAB387" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding IsModified, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 原編號 -->
                        <DataGridTextColumn Header="原始編號" Binding="{Binding OriginalNumber}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6C7086"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 新編號 -->
                        <DataGridTextColumn Header="圖紙編號 (雙擊修改)" Binding="{Binding SheetNumber, UpdateSourceTrigger=PropertyChanged}" Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#45475A"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <!-- 原名稱 -->
                        <DataGridTextColumn Header="原始名稱" Binding="{Binding OriginalName}" Width="150" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6C7086"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 新名稱 -->
                        <DataGridTextColumn Header="圖紙名稱 (雙擊修改)" Binding="{Binding SheetName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#45475A"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- 3. 底部按鈕區 -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 狀態列 -->
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="#FAB387" 
                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>

            <!-- 按鈕 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="確定更新 (Save)" Style="{StaticResource PrimaryBtn}" 
                        Command="{Binding SaveCommand}" Width="130" Height="30" Margin="0,0,10,0"/>
                <Button Content="取消 (Cancel)" Style="{StaticResource BaseBtn}" 
                        Command="{Binding CancelCommand}" Width="100" Height="30"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
