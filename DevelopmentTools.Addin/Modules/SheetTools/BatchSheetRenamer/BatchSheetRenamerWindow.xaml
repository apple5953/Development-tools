<Window x:Class="DevelopmentTools.Modules.SheetTools.BatchSheetRenamer.BatchSheetRenamerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:DevelopmentTools.Core"
        Title="{Binding [BatchRename_Title], Source={x:Static core:LanguageManager.Instance}}" Height="620" Width="880"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- 基礎按鈕樣式 -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要按鈕樣式 (藍色) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- 套用按鈕樣式 (綠色) -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#F5E0DC"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#CBA6F7"/>
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉選單樣式 -->
        <!-- 工具箱小面板樣式 -->
        <Style x:Key="ToolPanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 工具面板小標題 -->
        <Style x:Key="ToolHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5C2E7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 欄位標籤樣式 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <!-- DataGrid 樣式 -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush" Value="#313244"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <!-- DataGridCell 樣式 -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#F5E0DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- 標題與搜尋 -->
            <RowDefinition Height="Auto"/>
            <!-- 主要內容 (左邊工具箱，右邊清單) -->
            <RowDefinition Height="*"/>
            <!-- 底部按鈕區 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 標題與搜尋過濾 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding [BatchRename_Title], Source={x:Static core:LanguageManager.Instance}}" FontSize="16" FontWeight="Bold" Foreground="#CBA6F7"/>
                <TextBlock Text="{Binding [BatchRename_SubTitle], Source={x:Static core:LanguageManager.Instance}}" FontSize="10" Foreground="#89B4FA" Margin="0,2,0,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="{Binding [BatchRename_KeywordFilter], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                <TextBox Width="200" Style="{StaticResource DarkTextBox}" 
                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="{Binding [BatchRename_KeywordTooltip], Source={x:Static core:LanguageManager.Instance}}"/>
            </StackPanel>

            <Button Grid.Column="2" 
                    Content="{Binding [TileSys_Tutorial], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource BaseBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="10,0"
                    VerticalAlignment="Center"
                    ToolTip="{Binding [TileSys_TutorialDesc], Source={x:Static core:LanguageManager.Instance}}"/>
        </Grid>

        <!-- 2. 主要內容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左側工具箱 -->
                <ColumnDefinition Width="260"/>
                <!-- 間距 -->
                <ColumnDefinition Width="10"/>
                <!-- 右側 DataGrid 清單 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側工具箱 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,2,0">
                    
                    <!-- 面板：尋找與取代 -->
                    <Border Style="{StaticResource ToolPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [BatchRename_FindReplaceTitle], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource ToolHeader}"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_TargetField], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox  Grid.Column="1"  
                                          SelectedIndex="{Binding FindReplaceTarget}">
                                    <ComboBoxItem Content="{Binding [BatchRename_TargetNumber], Source={x:Static core:LanguageManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [BatchRename_TargetName], Source={x:Static core:LanguageManager.Instance}}"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_FindText], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_ReplaceText], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Button Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding ApplyFindReplaceCommand}" Margin="0,6,0,0"
                                    ToolTip="{Binding [BatchRename_ApplyReplaceTooltip], Source={x:Static core:LanguageManager.Instance}}">
                                <TextBlock Text="{Binding [BatchRename_ApplyReplaceBtn], Source={x:Static core:LanguageManager.Instance}}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 面板：加首綴與尾綴 -->
                    <Border Style="{StaticResource ToolPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [BatchRename_PrefixSuffixTitle], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource ToolHeader}"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_TargetField], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox  Grid.Column="1"  
                                          SelectedIndex="{Binding PrefixSuffixTarget}">
                                    <ComboBoxItem Content="{Binding [BatchRename_TargetNumber], Source={x:Static core:LanguageManager.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [BatchRename_TargetName], Source={x:Static core:LanguageManager.Instance}}"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_PrefixChar], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding PrefixText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_SuffixChar], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding SuffixText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Button Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding ApplyPrefixSuffixCommand}" Margin="0,6,0,0"
                                    ToolTip="{Binding [BatchRename_ApplyPrefixSuffixTooltip], Source={x:Static core:LanguageManager.Instance}}">
                                <TextBlock Text="{Binding [BatchRename_ApplyPrefixSuffixBtn], Source={x:Static core:LanguageManager.Instance}}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 面板：自動序號重排 -->
                    <Border Style="{StaticResource ToolPanelBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding [BatchRename_AutoIndexTitle], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource ToolHeader}"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_StartNumber], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" 
                                         Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [BatchRename_StartNumberTooltip], Source={x:Static core:LanguageManager.Instance}}"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding [BatchRename_Increment], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" 
                                         Text="{Binding Increment, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [BatchRename_IncrementTooltip], Source={x:Static core:LanguageManager.Instance}}"/>
                            </Grid>
                            <Button Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding ApplyAutoReindexCommand}" Margin="0,6,0,0"
                                    ToolTip="{Binding [BatchRename_ApplyAutoIndexTooltip], Source={x:Static core:LanguageManager.Instance}}">
                                <TextBlock Text="{Binding [BatchRename_ApplyAutoIndexBtn], Source={x:Static core:LanguageManager.Instance}}" />
                            </Button>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- 右側 DataGrid 清單 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- DataGrid 上方工具列 (全選等) -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource BaseBtn}" 
                                Command="{Binding ToggleSelectAllCommand}" Height="22" FontSize="10">
                            <TextBlock Text="{Binding [BatchRename_InvertSelection], Source={x:Static core:LanguageManager.Instance}}" />
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding [BatchRename_EditHint], Source={x:Static core:LanguageManager.Instance}}" 
                               Foreground="#A6ADC8" FontSize="10" FontStyle="Italic"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredSheets}"
                          Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- 勾選框 -->
                        <DataGridTemplateColumn Width="38">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 修改標誌 -->
                        <DataGridTemplateColumn Width="45">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{Binding [BatchRename_ColModified], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="✏️" Foreground="#FAB387" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding IsModified, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 原編號 -->
                        <DataGridTextColumn Binding="{Binding OriginalNumber}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [BatchRename_ColOriginalNum], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6C7086"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 新編號 -->
                        <DataGridTextColumn Binding="{Binding SheetNumber, UpdateSourceTrigger=PropertyChanged}" Width="160">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [BatchRename_ColNewNum], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#45475A"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <!-- 原名稱 -->
                        <DataGridTextColumn Binding="{Binding OriginalName}" Width="150" IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [BatchRename_ColOriginalName], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6C7086"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 新名稱 -->
                        <DataGridTextColumn Binding="{Binding SheetName, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [BatchRename_ColNewName], Source={x:Static core:LanguageManager.Instance}}" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#45475A"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- 3. 底部按鈕區 -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 狀態列 -->
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="#FAB387" 
                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>

            <!-- 按鈕 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryBtn}" 
                        Command="{Binding SaveCommand}" Width="130" Height="30" Margin="0,0,10,0">
                    <TextBlock Text="{Binding [BatchRename_SaveBtn], Source={x:Static core:LanguageManager.Instance}}" />
                </Button>
                <Button Style="{StaticResource BaseBtn}" 
                        Command="{Binding CancelCommand}" Width="100" Height="30">
                    <TextBlock Text="{Binding [BatchRename_CancelBtn], Source={x:Static core:LanguageManager.Instance}}" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
