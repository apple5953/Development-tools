<Window x:Class="DevelopmentTools.UI.DT_TileElevationGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="clr-namespace:DevelopmentTools.Core"
        Title="{Binding [TileElev_Title], Source={x:Static core:LanguageManager.Instance}}" Height="480" Width="660"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4CCFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5e81f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2,8,0,2"/>
        </Style>
        
        <Style x:Key="NormalText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 標題 -->
            <RowDefinition Height="Auto"/> <!-- 來源選取 -->
            <RowDefinition Height="*"/>    <!-- 參數設定 -->
            <RowDefinition Height="Auto"/> <!-- Action -->
            <RowDefinition Height="Auto"/> <!-- 狀態列 -->
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="🖼️  DT_TileElevationGenerator"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#CBA6F7"/>
                <TextBlock Text="{Binding [TileElev_SubTitle], Source={x:Static core:LanguageManager.Instance}}"
                           FontSize="9" FontWeight="Medium"
                           Foreground="#89B4FA"
                           Margin="2,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Content="{Binding [TileElev_HelpBtn], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="8,0"
                    VerticalAlignment="Center"
                    ToolTip="{Binding [TileElev_HelpTooltip], Source={x:Static core:LanguageManager.Instance}}"/>
        </Grid>

        <!-- 來源選取 -->
        <Border Grid.Row="1" Background="#181825" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding [TileElev_SourceModeTitle], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" Content="{Binding [TileElev_ModeFloor], Source={x:Static core:LanguageManager.Instance}}" 
                                 IsChecked="{Binding IsFloorMode}" 
                                 Foreground="#CDD6F4" FontSize="11"
                                 Margin="0,0,6,0"
                                 Cursor="Hand"/>
                    <RadioButton Grid.Column="1" Content="{Binding [TileElev_ModeWall], Source={x:Static core:LanguageManager.Instance}}" 
                                 IsChecked="{Binding IsWallMode}" 
                                 Foreground="#CDD6F4" FontSize="11"
                                 Margin="6,0,0,0"
                                 Cursor="Hand"/>
                </Grid>
                
                <Button Content="{Binding [TileElev_SelectBtn], Source={x:Static core:LanguageManager.Instance}}" 
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource PrimaryBtn}" 
                        Margin="0,10,0,4"/>
                
                <TextBlock Text="{Binding SelectedElementText}" 
                           Foreground="#F9E2AF" 
                           FontSize="10" 
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 參數設定 (雙欄佈局) -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左欄：視圖與圖紙設定 -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="視圖與圖紙設定" Style="{StaticResource SectionLabel}"/>
                
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [TileElev_ViewTemplate], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                    <ComboBox  Grid.Column="1" ItemsSource="{Binding ViewTemplates}" 
                              SelectedItem="{Binding SelectedTemplate}" 
                              DisplayMemberPath="Name" 
                              Height="24"
                              BorderThickness="1" BorderBrush="#45475A"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [TileElev_ViewPrefix], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [TileElev_TitleBlock], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                    <ComboBox  Grid.Column="1" ItemsSource="{Binding TitleBlocks}" 
                              SelectedItem="{Binding SelectedTitleBlock}" 
                              DisplayMemberPath="Name" 
                              Height="24"
                              BorderThickness="1" BorderBrush="#45475A"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [TileElev_ViewportType], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                    <ComboBox  Grid.Column="1" ItemsSource="{Binding ViewportTypes}" 
                              SelectedItem="{Binding SelectedViewportType}" 
                              DisplayMemberPath="Name" 
                              Height="24"
                              BorderThickness="1" BorderBrush="#45475A"/>
                </Grid>

                <TextBlock Text="{Binding [TileElev_Tip], Source={x:Static core:LanguageManager.Instance}}" 
                           Foreground="#89B4FA" FontSize="9.5" Margin="2,16,0,0" TextWrapping="Wrap" LineHeight="14"/>
            </StackPanel>

            <!-- 右欄：幾何與範圍參數 -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="幾何與範圍參數" Style="{StaticResource SectionLabel}"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="剖面視圖深度 (mm)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding ViewDepth, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [TileElev_SidePadding], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding SideExtension, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="頂部偏移 (mm)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding TopOffset, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="底部偏移 (mm)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding BottomOffset, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>
                
                <TextBlock Text="💡 提示：剖面頂部與底部範圍是根據您選取的樓板/牆體高程自動抓取基準，再疊加此處設定的偏移量生成。" 
                           Foreground="#89B4FA" FontSize="9.5" Margin="2,16,0,0" TextWrapping="Wrap" LineHeight="14"/>
            </StackPanel>
        </Grid>

        <!-- Action -->
        <StackPanel Grid.Row="3" Margin="0,6,0,0">
            <!-- 逐步製作除錯面板 -->
            <Border Background="#181825" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{Binding [TileElev_StepTitle], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Button Grid.Column="0" Grid.Row="0" Content="{Binding [TileElev_Step1], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step1AnalyzeCommand}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                                
                        <Button Grid.Column="1" Grid.Row="0" Content="{Binding [TileElev_Step2], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step2CreateCommand}"
                                IsEnabled="{Binding IsStep2Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                                
                        <Button Grid.Column="0" Grid.Row="1" Content="{Binding [TileElev_Step3], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step3ApplyTemplateCommand}"
                                IsEnabled="{Binding IsStep3Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                                
                        <Button Grid.Column="1" Grid.Row="1" Content="{Binding [TileElev_Step4], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step4RenameCommand}"
                                IsEnabled="{Binding IsStep4Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>

                        <Button Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Content="{Binding [TileElev_Step5], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step5CreateSheetCommand}"
                                IsEnabled="{Binding IsStep5Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 一鍵產生與關閉 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{Binding [TileElev_GenerateBtn], Source={x:Static core:LanguageManager.Instance}}" 
                        Command="{Binding GenerateCommand}"
                        Style="{StaticResource GreenBtn}"
                        Foreground="#1E1E2E"
                        Height="34" Margin="0,0,4,0"/>
                <Button Grid.Column="1" Content="{Binding [Common_Close], Source={x:Static core:LanguageManager.Instance}}" 
                        Command="{Binding CloseWindowCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Background="#45475A" Foreground="#CDD6F4"
                        Height="34" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                Margin="0,8,0,0" Padding="8,4" MinHeight="35">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A6E3A1"
                       FontSize="10"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
