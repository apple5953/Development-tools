<Window x:Class="DevelopmentTools.UI.DT_TileElevationGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="clr-namespace:DevelopmentTools.Core"
        Title="{Binding [TileElev_Title], Source={x:Static core:LanguageManager.Instance}}" Height="650" Width="1020"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4CCFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5e81f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,4,0,2"/>
        </Style>
        
        <Style x:Key="NormalText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Styles -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="RowBackground" Value="#1E1E2E"/>
            <Setter Property="AlternatingRowBackground" Value="#181825"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush" Value="#313244"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#F5E0DC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 標題 -->
            <RowDefinition Height="Auto"/> <!-- 來源選取 -->
            <RowDefinition Height="*"/>    <!-- 參數設定與示意圖 -->
            <RowDefinition Height="Auto"/> <!-- Action -->
            <RowDefinition Height="Auto"/> <!-- 狀態列 -->
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="🖼️  DT_TileElevationGenerator"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#CBA6F7"/>
                <TextBlock Text="{Binding [TileElev_SubTitle], Source={x:Static core:LanguageManager.Instance}}"
                           FontSize="9" Foreground="#89B4FA" Margin="2,1,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Content="{Binding [TileElev_HelpBtn], Source={x:Static core:LanguageManager.Instance}}"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="20"
                    Padding="6,0"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- 來源選取 -->
        <Border Grid.Row="1" Background="#181825" CornerRadius="6" Padding="8,6" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="選取來源物件模式：" Style="{StaticResource NormalText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <RadioButton Grid.Column="1" Content="{Binding [TileElev_ModeFloor], Source={x:Static core:LanguageManager.Instance}}" 
                              IsChecked="{Binding IsFloorMode}" 
                              Foreground="#CDD6F4" FontSize="11" VerticalAlignment="Center" Cursor="Hand"/>
                <RadioButton Grid.Column="2" Content="{Binding [TileElev_ModeWall], Source={x:Static core:LanguageManager.Instance}}" 
                              IsChecked="{Binding IsWallMode}" 
                              Foreground="#CDD6F4" FontSize="11" VerticalAlignment="Center" Cursor="Hand"/>
                
                <Button Grid.Column="3" Content="{Binding [TileElev_SelectBtn], Source={x:Static core:LanguageManager.Instance}}" 
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource PrimaryBtn}" Height="24" Margin="10,0,0,0"/>
                
                <TextBlock Grid.Column="4" Text="{Binding SelectedElementText}" 
                           Foreground="#F9E2AF" FontSize="10" Margin="15,0,0,0"
                           VerticalAlignment="Center" TextWrapping="NoWrap"/>
            </Grid>
        </Border>

        <!-- 參數設定與示意圖三欄佈局 -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <!-- 左欄：設定與清單 -->
                <ColumnDefinition Width="480"/>
                <ColumnDefinition Width="10"/>
                <!-- 中欄：當前選中剖面的微調參數 -->
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="10"/>
                <!-- 右欄：即時圖形預覽 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左欄：視圖與圖紙設定 + 剖面清單 DataGrid -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 設定標題 -->
                    <RowDefinition Height="Auto"/> <!-- 各下拉選單與前綴 -->
                    <RowDefinition Height="Auto"/> <!-- 清單標題 -->
                    <RowDefinition Height="*"/>    <!-- DataGrid 清單 -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="視圖與圖紙設定" Style="{StaticResource SectionLabel}"/>
                
                <StackPanel Grid.Row="1" Margin="0,0,0,4">
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [TileElev_ViewTemplate], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ViewTemplates}" 
                                  SelectedItem="{Binding SelectedTemplate}" 
                                  DisplayMemberPath="Name" 
                                  Height="24"
                                  BorderThickness="1" BorderBrush="#45475A"/>
                    </Grid>

                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [TileElev_ViewPrefix], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                        <TextBox Grid.Column="1" Text="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                    </Grid>

                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [TileElev_TitleBlock], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding TitleBlocks}" 
                                  SelectedItem="{Binding SelectedTitleBlock}" 
                                  DisplayMemberPath="Name" 
                                  Height="24"
                                  BorderThickness="1" BorderBrush="#45475A"/>
                    </Grid>

                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [TileElev_ViewportType], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource NormalText}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ViewportTypes}" 
                                  SelectedItem="{Binding SelectedViewportType}" 
                                  DisplayMemberPath="Name" 
                                  Height="24"
                                  BorderThickness="1" BorderBrush="#45475A"/>
                    </Grid>

                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="基準樓層 (Base Level)" Style="{StaticResource NormalText}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ProjectLevels}" 
                                  SelectedItem="{Binding SelectedBaseLevel}" 
                                  DisplayMemberPath="Name" 
                                  Height="24"
                                  BorderThickness="1" BorderBrush="#45475A"/>
                    </Grid>

                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="頂部樓層 (Top Level)" Style="{StaticResource NormalText}"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ProjectLevels}" 
                                  SelectedItem="{Binding SelectedTopLevel}" 
                                  DisplayMemberPath="Name" 
                                  Height="24"
                                  BorderThickness="1" BorderBrush="#45475A"/>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="2" Margin="2,4,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="剖刀視圖清單 (雙擊更名/點擊右側上下移動順序)" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content=" ▲ 上移 " 
                            Command="{Binding MoveUpCommand}"
                            Style="{StaticResource PrimaryBtn}" 
                            Height="18" Padding="6,0" Margin="0,0,4,0" FontSize="9"/>
                    <Button Grid.Column="2" Content=" ▼ 下移 " 
                            Command="{Binding MoveDownCommand}"
                            Style="{StaticResource PrimaryBtn}" 
                            Height="18" Padding="6,0" FontSize="9"/>
                </Grid>
                
                <!-- 剖刀清單 DataGrid -->
                <DataGrid Grid.Row="3" ItemsSource="{Binding ElevationItems}" SelectedItem="{Binding SelectedElevationItem, Mode=TwoWay}" Style="{StaticResource DarkDataGrid}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkDataGridHeader}"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="40">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="啟用" HorizontalAlignment="Center"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="剖面名稱 (雙擊更名)" Binding="{Binding ViewName, UpdateSourceTrigger=PropertyChanged}" Width="*" IsReadOnly="False">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="CaretBrush" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="長度" Binding="{Binding WallLength, StringFormat=\{0:F0\}}" Width="55" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="高度" Binding="{Binding WallHeight, StringFormat=\{0:F0\}}" Width="55" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="底部" Binding="{Binding BaseElevation, StringFormat=\{0:F0\}}" Width="55" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="頂部" Binding="{Binding TopElevation, StringFormat=\{0:F0\}}" Width="55" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,4,0"/>
                                    <Setter Property="Foreground" Value="#BAC2E0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- 中欄：幾何與範圍參數 (連動 SelectedElevationItem) -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="當前剖刀微調參數" Style="{StaticResource SectionLabel}"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="前移距離 WallOffset" Style="{StaticResource NormalText}" ToolTip="剖切位置向內移動的距離 (mm)"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedElevationItem.WallOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="剖面深度 ViewDepth" Style="{StaticResource NormalText}" ToolTip="剖切視圖後看的深度範圍 (mm)"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedElevationItem.ViewDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="兩側延伸 SideExtension" Style="{StaticResource NormalText}" ToolTip="剖刀寬度向兩側延伸的長度 (mm)"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedElevationItem.SideExtension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="頂部偏移 TopOffset" Style="{StaticResource NormalText}" ToolTip="裁切框頂部偏移 (mm)"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedElevationItem.TopOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="底部偏移 BottomOffset" Style="{StaticResource NormalText}" ToolTip="裁切框底部偏移 (mm)"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedElevationItem.BottomOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="相反方向 (反轉)" Style="{StaticResource NormalText}" ToolTip="將剖切方向反轉 180 度"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding SelectedElevationItem.FlipDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>

                <Button Content="套用此設定至所有剖刀 (設為預設)" 
                        Command="{Binding SetAsDefaultCommand}"
                        Style="{StaticResource PrimaryBtn}" 
                        Background="#FAB387" Foreground="#1E1E2E"
                        Height="24" Margin="0,8,0,0"/>
                
                <TextBlock Text="💡 提示：在左側清單點選不同的剖刀項目，即可單獨調整該切面的前移距離、深度、延伸量與高程範圍。右側示意圖將即時連動呈現該剖刀的位置。" 
                           Foreground="#89B4FA" FontSize="9.5" Margin="2,12,0,0" TextWrapping="Wrap" LineHeight="14"/>
            </StackPanel>

            <!-- 右欄：剖刀即時雙向示意圖 (平面 + 立面，滿版與深度範圍指示) -->
            <Border Grid.Column="4" Background="#181825" CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/> <!-- 平面圖 -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/> <!-- 立面圖 -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="📐 剖切定位即時示意 (Plan &amp; Section Previews)" 
                               Foreground="#FAB387" FontWeight="Bold" FontSize="10.5" 
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    
                    <!-- 1. 平面俯視圖 Plan View Canvas -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="4,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="平面俯視 (滾輪縮放 / 按住左鍵拖移)" Foreground="#A6E3A1" FontSize="9.5" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ZoomPercentText}" Foreground="#FAB387" FontSize="9.5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content=" 🔄 重置預覽 " Click="Button_ResetView_Click" Style="{StaticResource PrimaryBtn}" Height="18" Padding="6,0" FontSize="9"/>
                        </Grid>
                        <Canvas x:Name="PlanCanvas" Grid.Row="1" Background="#11111B" ClipToBounds="True" 
                                MouseWheel="Canvas_MouseWheel"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                MouseMove="Canvas_MouseMove">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform X="0" Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                            <TextBlock Text="{Binding SelectedSectionIndexText}" Foreground="#FAB387" FontSize="9" Canvas.Left="10" Canvas.Top="4"/>
                            
                            <!-- 1. 實際選取的樓板多邊形 -->
                            <Polygon Points="{Binding FloorPolygonPoints}" Stroke="#585B70" StrokeThickness="3.5" Fill="#0A585B70"/>
                            <TextBlock Text="選取樓板範圍" Foreground="#CDD6F4" FontSize="8.5" Canvas.Left="40" Canvas.Top="16"/>

                            <!-- 2. 剖面視圖深度範圍半透明區域 -->
                            <Polygon Points="{Binding SelectedDepthRangePoints}" Fill="#2289B4FA" Stroke="#89B4FA" StrokeThickness="1" StrokeDashArray="2,2"/>
                            
                            <!-- 3. 當前選中剖刀線 -->
                            <Line X1="{Binding SelectedCutLineX1}" Y1="{Binding SelectedCutLineY1}" 
                                  X2="{Binding SelectedCutLineX2}" Y2="{Binding SelectedCutLineY2}" 
                                  Stroke="#F38BA8" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <TextBlock Text="✦ 剖刀切線" Foreground="#F38BA8" FontSize="8.5" FontWeight="Bold"
                                       Canvas.Left="{Binding SelectedCutLineX1}" Canvas.Top="{Binding SelectedCutLineY1}"/>
                        </Canvas>
                    </Grid>

                    <!-- 2. 立面剖視圖 Section View Canvas -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="立面剖視高度 (Section View Height Preview)" Foreground="#89B4FA" FontSize="9.5" Margin="4,0,0,2"/>
                        <Canvas x:Name="SectionCanvas" Grid.Row="1" Background="#11111B" ClipToBounds="True" 
                                MouseWheel="Canvas_MouseWheel"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                MouseMove="Canvas_MouseMove">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform X="0" Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                            <!-- 地板 -->
                            <Line X1="10" Y1="{Binding DrawFloorY}" X2="270" Y2="{Binding DrawFloorY}" Stroke="#7F849C" StrokeThickness="1.5"/>
                            <TextBlock Text="當前樓板面 (Level Floor)" Foreground="#7F849C" FontSize="8.5" Canvas.Left="15" Canvas.Top="88"/>

                            <!-- 天花板 -->
                            <Line X1="10" Y1="{Binding DrawCeilingY}" X2="270" Y2="{Binding DrawCeilingY}" Stroke="#7F849C" StrokeThickness="1" StrokeDashArray="2,2"/>
                            <TextBlock Text="上層樓板面/天花高度 (Upper Level)" Foreground="#7F849C" FontSize="8.5" Canvas.Left="15" Canvas.Top="{Binding DrawCeilingTextTop}"/>

                            <!-- 剖切範圍 -->
                            <Rectangle Fill="#1A89B4FA" Stroke="#89B4FA" StrokeThickness="1.5" StrokeDashArray="2,2"
                                       Canvas.Left="80" 
                                       Canvas.Top="{Binding DrawSectionCropTop}" 
                                       Width="120" 
                                       Height="{Binding DrawSectionCropHeight}"/>
                            
                            <TextBlock Text="剖面裁剪高度範圍" Foreground="#89B4FA" FontSize="8.5" FontWeight="SemiBold"
                                       Canvas.Left="95" Canvas.Top="45"/>
                                       
                            <!-- 顯示頂底偏移的文字標註 -->
                            <TextBlock Text="{Binding SelectedElevationItem.TopOffset, StringFormat=頂部偏移: \{0\} mm}" Foreground="#F9E2AF" FontSize="8"
                                       Canvas.Left="85" Canvas.Top="{Binding DrawCeilingY}"/>
                            <TextBlock Text="{Binding SelectedElevationItem.BottomOffset, StringFormat=底部偏移: \{0\} mm}" Foreground="#F9E2AF" FontSize="8"
                                       Canvas.Left="85" Canvas.Top="68"/>
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Action -->
        <StackPanel Grid.Row="3" Margin="0,6,0,0">
            <!-- 逐步製作除錯面板 -->
            <Border Background="#181825" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{Binding [TileElev_StepTitle], Source={x:Static core:LanguageManager.Instance}}" Style="{StaticResource SectionLabel}" Margin="2,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Button Grid.Column="0" Content="{Binding [TileElev_Step1], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step1AnalyzeCommand}"
                                Style="{StaticResource PrimaryBtn}" Margin="2,0"/>
                                
                        <Button Grid.Column="1" Content="{Binding [TileElev_Step2], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step2CreateCommand}"
                                IsEnabled="{Binding IsStep2Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2,0"/>
                                
                        <Button Grid.Column="2" Content="{Binding [TileElev_Step3], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step3ApplyTemplateCommand}"
                                IsEnabled="{Binding IsStep3Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2,0"/>
                                
                        <Button Grid.Column="3" Content="{Binding [TileElev_Step4], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step4RenameCommand}"
                                IsEnabled="{Binding IsStep4Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2,0"/>

                        <Button Grid.Column="4" Content="{Binding [TileElev_Step5], Source={x:Static core:LanguageManager.Instance}}" 
                                Command="{Binding Step5CreateSheetCommand}"
                                IsEnabled="{Binding IsStep5Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 一鍵產生與關閉 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{Binding [TileElev_GenerateBtn], Source={x:Static core:LanguageManager.Instance}}" 
                        Command="{Binding GenerateCommand}"
                        Style="{StaticResource GreenBtn}"
                        Foreground="#1E1E2E"
                        Height="34" Margin="0,0,4,0"/>
                <Button Grid.Column="1" Content="{Binding [Common_Close], Source={x:Static core:LanguageManager.Instance}}" 
                        Command="{Binding CloseWindowCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Background="#45475A" Foreground="#CDD6F4"
                        Height="34" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                Margin="0,8,0,0" Padding="8,4" MinHeight="35">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A6E3A1"
                       FontSize="10"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
