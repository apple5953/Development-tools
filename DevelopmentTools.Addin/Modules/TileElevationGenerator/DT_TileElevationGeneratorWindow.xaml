<Window x:Class="DevelopmentTools.UI.DT_TileElevationGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="磁磚展開圖生成器 v3" Height="570" Width="380"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4CCFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5e81f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2,8,0,2"/>
        </Style>
        
        <Style x:Key="NormalText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 標題 -->
            <RowDefinition Height="Auto"/> <!-- 來源選取 -->
            <RowDefinition Height="*"/>    <!-- 參數設定 -->
            <RowDefinition Height="Auto"/> <!-- Action -->
            <RowDefinition Height="Auto"/> <!-- 狀態列 -->
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="🖼️  DT_TileElevationGenerator"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#CBA6F7"/>
                <TextBlock Text="磁磚展開圖自動化生成系統"
                           FontSize="9" FontWeight="Medium"
                           Foreground="#89B4FA"
                           Margin="2,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Content="❓ 新手教學"
                    Command="{Binding OpenHelpCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Background="#F9E2AF"
                    Foreground="#1E1E2E"
                    Height="24"
                    Padding="8,0"
                    VerticalAlignment="Center"
                    ToolTip="點擊開啟磁磚展開圖生成器快速入門與使用指南"/>
        </Grid>

        <!-- 來源選取 -->
        <Border Grid.Row="1" Background="#181825" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="▍ 選擇來源模式 (Source Mode)" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" Content="Floor 模式 (自動相鄰牆)" 
                                 IsChecked="{Binding IsFloorMode}" 
                                 Foreground="#CDD6F4" FontSize="11"
                                 Margin="0,0,6,0"
                                 Cursor="Hand"/>
                    <RadioButton Grid.Column="1" Content="Wall 模式 (手動多選牆)" 
                                 IsChecked="{Binding IsWallMode}" 
                                 Foreground="#CDD6F4" FontSize="11"
                                 Margin="6,0,0,0"
                                 Cursor="Hand"/>
                </Grid>
                
                <Button Content="🖱️ 點選並選取 Revit 目標物件" 
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource PrimaryBtn}" 
                        Margin="0,10,0,4"/>
                
                <TextBlock Text="{Binding SelectedElementText}" 
                           Foreground="#F9E2AF" 
                           FontSize="10" 
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 參數設定 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel Margin="0,0,6,0">
                <TextBlock Text="▍ 剖面視圖設定 (Section Settings)" Style="{StaticResource SectionLabel}"/>
                
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="視圖樣板" Style="{StaticResource NormalText}"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding ViewTemplates}" 
                              SelectedItem="{Binding SelectedTemplate}" 
                              DisplayMemberPath="Name" 
                              Height="24" Background="#313244" Foreground="#CDD6F4"
                              BorderThickness="1" BorderBrush="#45475A"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="視圖前置詞" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <TextBlock Text="💡 提示：本工具使用極致自動化物理邏輯，其餘所有幾何參數 (剖切深度、前移偏移量、上下拉延伸等) 均由系統自動進行自適應計算，不需手動輸入。" 
                           Foreground="#89B4FA" FontSize="9.5" Margin="2,16,0,0" TextWrapping="Wrap" LineHeight="14"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Action -->
        <StackPanel Grid.Row="3" Margin="0,6,0,0">
            <!-- 逐步製作除錯面板 -->
            <Border Background="#181825" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="▍ 逐步製作與除錯 (Step-by-step Workflow)" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Button Grid.Column="0" Grid.Row="0" Content="1. 分析幾何" 
                                Command="{Binding Step1AnalyzeCommand}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                                
                        <Button Grid.Column="1" Grid.Row="0" Content="2. 建立視圖" 
                                Command="{Binding Step2CreateCommand}"
                                IsEnabled="{Binding IsStep2Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                                
                        <Button Grid.Column="0" Grid.Row="1" Content="3. 套用樣板" 
                                Command="{Binding Step3ApplyTemplateCommand}"
                                IsEnabled="{Binding IsStep3Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                                
                        <Button Grid.Column="1" Grid.Row="1" Content="4. 重新命名" 
                                Command="{Binding Step4RenameCommand}"
                                IsEnabled="{Binding IsStep4Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>

                        <Button Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Content="5. 建立圖紙並置入視圖" 
                                Command="{Binding Step5CreateSheetCommand}"
                                IsEnabled="{Binding IsStep5Enabled}"
                                Style="{StaticResource PrimaryBtn}" Margin="2"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 一鍵產生與關閉 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="🚀 一鍵自動產生展開圖" 
                        Command="{Binding GenerateCommand}"
                        Style="{StaticResource GreenBtn}"
                        Foreground="#1E1E2E"
                        Height="34" Margin="0,0,4,0"/>
                <Button Grid.Column="1" Content="關閉" 
                        Command="{Binding CloseWindowCommand}"
                        Style="{StaticResource PrimaryBtn}"
                        Background="#45475A" Foreground="#CDD6F4"
                        Height="34" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                Margin="0,8,0,0" Padding="8,4" MinHeight="35">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A6E3A1"
                       FontSize="10"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
