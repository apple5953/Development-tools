<Window x:Class="DevelopmentTools.UI.DT_TileElevationGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="磁磚展開圖生成器 v3" Height="540" Width="340"
        Background="#1E1E2E" Foreground="#CDD6F4" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4CCFB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5e81f4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#A6E3A1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="2,8,0,2"/>
        </Style>
        
        <Style x:Key="NormalText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 標題 -->
            <RowDefinition Height="Auto"/> <!-- 來源選取 -->
            <RowDefinition Height="*"/>    <!-- 參數設定 -->
            <RowDefinition Height="Auto"/> <!-- Action -->
            <RowDefinition Height="Auto"/> <!-- 狀態列 -->
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="🖼️  DT_TileElevationGenerator"
                       FontSize="14" FontWeight="Bold"
                       Foreground="#CBA6F7"/>
            <TextBlock Text="磁磚展開圖自動化生成系統"
                       FontSize="9" FontWeight="Medium"
                       Foreground="#89B4FA"
                       Margin="2,2,0,0"/>
        </StackPanel>

        <!-- 來源選取 -->
        <Border Grid.Row="1" Background="#181825" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="▍ 選擇來源模式 (Source Mode)" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" Content="Floor 模式 (自動相鄰牆)" 
                                 IsChecked="{Binding IsFloorMode}" 
                                 Foreground="#CDD6F4" FontSize="11"
                                 Cursor="Hand"/>
                    <RadioButton Grid.Column="1" Content="Wall 模式 (手動多選牆)" 
                                 IsChecked="{Binding IsWallMode}" 
                                 Foreground="#CDD6F4" FontSize="11"
                                 Cursor="Hand"/>
                </Grid>
                
                <Button Content="🖱️ 點選並選取 Revit 目標物件" 
                        Command="{Binding SelectSourceCommand}"
                        Style="{StaticResource PrimaryBtn}" 
                        Margin="0,10,0,4"/>
                
                <TextBlock Text="{Binding SelectedElementText}" 
                           Foreground="#F9E2AF" 
                           FontSize="10" 
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 參數設定 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel Margin="0,0,6,0">
                <TextBlock Text="▍ 剖面視圖設定 (Section Settings)" Style="{StaticResource SectionLabel}"/>
                
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="View Template" Style="{StaticResource NormalText}"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding ViewTemplates}" 
                              SelectedItem="{Binding SelectedTemplate}" 
                              DisplayMemberPath="Name" 
                              Height="24" Background="#313244" Foreground="#CDD6F4"
                              BorderThickness="1" BorderBrush="#45475A"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="View Depth (剖面深度)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding Settings.ViewDepth}" Style="{StaticResource DarkTextBox}"/>
                    <TextBlock Grid.Column="2" Text="mm" Style="{StaticResource NormalText}" Margin="6,0,0,0" Foreground="#585B70"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Wall Offset (剖面線內縮)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding Settings.WallOffset}" Style="{StaticResource DarkTextBox}"/>
                    <TextBlock Grid.Column="2" Text="mm" Style="{StaticResource NormalText}" Margin="6,0,0,0" Foreground="#585B70"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bottom Offset (底部向下)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding Settings.BottomOffset}" Style="{StaticResource DarkTextBox}"/>
                    <TextBlock Grid.Column="2" Text="mm" Style="{StaticResource NormalText}" Margin="6,0,0,0" Foreground="#585B70"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name Prefix (視圖前綴)" Style="{StaticResource NormalText}"/>
                    <TextBox Grid.Column="1" Text="{Binding Settings.NamePrefix}" Style="{StaticResource DarkTextBox}"/>
                </Grid>

                <TextBlock Text="▍ 進階幾何篩選 (Advanced Filters)" Style="{StaticResource SectionLabel}"/>

                <CheckBox Content="自動偵測牆體高度 (Auto Height)" 
                          IsChecked="{Binding Settings.AutoWallHeight}" 
                          Foreground="#CDD6F4" FontSize="11" Margin="2,4"
                          Cursor="Hand"/>
                <CheckBox Content="自動偵測牆體長度 (Auto Length)" 
                          IsChecked="{Binding Settings.AutoWallLength}" 
                          Foreground="#CDD6F4" FontSize="11" Margin="2,4"
                          Cursor="Hand"/>
                <CheckBox Content="忽略過短的牆體 (Skip Short Wall)" 
                          IsChecked="{Binding Settings.SkipShortWall}" 
                          Foreground="#CDD6F4" FontSize="11" Margin="2,4"
                          Cursor="Hand"/>

                <Grid Margin="22,2,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Min Wall Length" Style="{StaticResource NormalText}" Foreground="#A6ADC8"/>
                    <TextBox Grid.Column="1" Text="{Binding Settings.MinWallLength}" Style="{StaticResource DarkTextBox}"/>
                    <TextBlock Grid.Column="2" Text="mm" Style="{StaticResource NormalText}" Margin="6,0,0,0" Foreground="#585B70"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Action -->
        <Button Grid.Row="3" Content="🚀  一鍵產生磁磚展開圖" 
                Command="{Binding GenerateCommand}"
                Style="{StaticResource GreenBtn}"
                Foreground="#1E1E2E"
                Height="40"/>

        <!-- 狀態列 -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="4"
                Margin="0,8,0,0" Padding="8,4" MinHeight="35">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A6E3A1"
                       FontSize="10"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
