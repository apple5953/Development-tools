<Window x:Class="DevelopmentTools.Modules.AIAssistant.AIAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DevelopmentTools.Modules.AIAssistant"
        Title="AI 模型分析助手" Height="720" Width="920"
        MinHeight="560" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        FontFamily="Microsoft JhengHei UI"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- 顏色 -->
        <SolidColorBrush x:Key="BgPrimary"     Color="#0F1117"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard"        Color="#1C2128"/>
        <SolidColorBrush x:Key="BgInput"       Color="#21262D"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#388BFD"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#D29922"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#F85149"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7D8590"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#30363D"/>

        <!-- 按鈕基礎樣式 -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Microsoft JhengHei UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="#0F1117"/>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- TextBox 樣式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Microsoft JhengHei UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar 細樣式 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- 使用者訊息氣泡 -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="1"
                        Background="{StaticResource AccentBlue}"
                        CornerRadius="12,2,12,12"
                        Padding="12,8"
                        MaxWidth="520"
                        HorizontalAlignment="Right">
                    <StackPanel>
                        <TextBlock Text="{Binding Content}"
                                   Foreground="White"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                   Foreground="#B0C8F0"
                                   FontSize="10"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- AI 訊息氣泡 -->
        <DataTemplate x:Key="AssistantMessageTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="2,12,12,12"
                        Padding="12,8"
                        MaxWidth="580"
                        HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="🤖  AI 助手"
                                   Foreground="{StaticResource AccentGreen}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Content}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                        <Button Content="⚡ 立即在 Revit 中執行 AI 修改"
                                Style="{StaticResource BtnPrimary}"
                                Margin="0,8,0,0"
                                Padding="8,4"
                                FontSize="11"
                                HorizontalAlignment="Left"
                                Command="{Binding DataContext.ExecuteRevitCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Visibility="{Binding HasCommand, Converter={x:Static local:BoolToVisibility.Instance}}"/>
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="10"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- 系統訊息 -->
        <DataTemplate x:Key="SystemMessageTemplate">
            <Border Background="#1C2534"
                    BorderBrush="#264567"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10"
                    Margin="0,4">
                <TextBlock Text="{Binding Content}"
                           Foreground="#A0BEDB"
                           FontSize="12"
                           TextWrapping="Wrap"
                           LineHeight="20"/>
            </Border>
        </DataTemplate>

        <!-- 訊息 DataTemplateSelector 替代：直接用 ContentControl -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 頂部標題列 -->
            <RowDefinition Height="*"/>     <!-- 主內容區 -->
            <RowDefinition Height="Auto"/>  <!-- 底部狀態列 -->
        </Grid.RowDefinitions>

        <!-- ── 頂部標題列 ─────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🤖" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="AI 模型分析助手"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource AccentOrange}"
                                   FontSize="11"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Button Style="{StaticResource BtnSecondary}"
                            Content="⚙ API 設定"
                            Command="{Binding ToggleConfigCommand}"
                            Padding="10,5"/></StackPanel>
            </Grid>
        </Border>

        <!-- ── 主內容區 ───────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側：元件資料面板 -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 左側標題 -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="🔍  選取元件資料"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"
                                       Margin="0,2,0,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="已選取 {0} 個元件">
                                        <Binding Path="SelectedCount"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 元件資料顯示 TabControl -->
                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="4">
                        <TabControl.Resources>
                            <!-- TabItem 樣式 -->
                            <Style TargetType="TabItem">
                                <Setter Property="HeaderTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <ContentPresenter Content="{TemplateBinding Content}" Margin="4,2"/>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="#161B22"/>
                                <Setter Property="Foreground" Value="#7D8590"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Margin="2,0" Padding="10,6">
                                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#1C2128"/>
                                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#30363D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- Tab 1: 📊 項目診斷 -->
                        <TabItem Header="📊 項目診斷">
                            <Grid Background="#1C2128" Margin="0,4,0,0">
                                <!-- 無缺失時的提示 -->
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,40,0,0"
                                            Visibility="{Binding HasNoQCIssues, Converter={x:Static local:BoolToVisibility.Instance}}">
                                    <TextBlock Text="🎉" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="BIM 模型狀態良好"
                                               Foreground="{StaticResource AccentGreen}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="目前無發現任何裝修或&#10;Uniclass 分類代碼缺失！"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="0,6,0,0"/>
                                </StackPanel>

                                <!-- 缺失 DataGrid -->
                                <DataGrid ItemsSource="{Binding QCIssues}"
                                          SelectedItem="{Binding SelectedIssue, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Background="Transparent"
                                          RowBackground="#1C2128"
                                          AlternatingRowBackground="#161B22"
                                          BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#30363D"
                                          Foreground="{StaticResource TextPrimary}"
                                          SelectionMode="Single"
                                          Visibility="{Binding HasQCIssues, Converter={x:Static local:BoolToVisibility.Instance}}">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#161B22"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#30363D"/>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#263E5E"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="樓層" Binding="{Binding LevelName}" Width="Auto"/>
                                        <DataGridTextColumn Header="類型" Binding="{Binding ElementType}" Width="Auto"/>
                                        <DataGridTextColumn Header="名稱/房號" Binding="{Binding ElementName}" Width="*"/>
                                        <DataGridTextColumn Header="問題" Binding="{Binding IssueType}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- Tab 2: 📝 原始 Context -->
                        <TabItem Header="📝 原始資料">
                            <Grid Background="#1C2128" Margin="0,4,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                                    <TextBox Text="{Binding ElementContext, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource DarkTextBox}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             TextWrapping="Wrap"
                                             FontSize="11"
                                             FontFamily="Consolas, Microsoft JhengHei UI"
                                             Foreground="#A8C4E0"/>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <!-- Tab 3: 📖 使用說明 -->
                        <TabItem Header="📖 使用說明">
                            <Grid Background="#1C2128" Margin="0,4,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="🤖 AI 助手與 ISO 19650 QC 指南" FontWeight="Bold" FontSize="13" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Text="1. API 連線設定" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,2"/>
                                        <TextBlock Text="點選右上角「⚙ API 設定」，輸入金鑰、端點（相容 OpenAI 格式，或本地離線 Ollama）並進行確認連線。" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="4,0,0,6"/>

                                        <TextBlock Text="2. 數據 Context 讀取 (雙模式)" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,2"/>
                                        <TextBlock Text="• 手動選取：選取 Revit 物件後點選「⬇ 讀取 Revit 資料」進行局部優化與審查。&#x0a;• 免選取全域掃描：未選取物件時點選，自動檢驗各樓層牆體/地板 Uniclass 編碼與空間裝修參數缺漏。" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="4,0,0,6"/>

                                        <TextBlock Text="3. 對話與一鍵寫回優化" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,2"/>
                                        <TextBlock Text="可詢問 AI「幫我檢查各樓層裝修」或「2F 還有哪些房間沒建好」。對話中若出現「⚡ 執行 AI 修改」按鈕，點擊後會彈出 Revit 原生 TaskDialog 二次確認並顯示新舊值對照表（長度自動換算 mm），按下 Yes 才會 commit 寫入，保證安全！" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="4,0,0,6"/>
                                        
                                        <TextBlock Text="4. Revit 雙向連動高亮" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,2"/>
                                        <TextBlock Text="在「📊 項目診斷」列表中，直接滑鼠點擊任意一列缺失問題，Revit 視圖中會同步高亮選取該物件，方便立即核對。" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="4,0,0,6"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- 取得元件按鈕 -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,1,0,0"
                            Padding="14,10">
                        <StackPanel>
                            <Button x:Name="BtnGetSelection"
                                    Style="{StaticResource BtnSuccess}"
                                    Content="⬇  讀取 Revit 資料 (選取/全專案掃描)"
                                    Click="BtnGetSelection_Click"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"/>
                            <Button Style="{StaticResource BtnPrimary}"
                                    Content="🤖  送出分析"
                                    Command="{Binding SubmitAnalysisCommand}"
                                    HorizontalAlignment="Stretch"
                                    ToolTip="送出元件資料以取得 AI 分析建議"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 分隔線（可拖曳，視覺上的分隔符） -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderColor}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- 右側：對話區 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>   <!-- 對話歷史 -->
                    <RowDefinition Height="Auto"/> <!-- 建置中橫幅 -->
                    <RowDefinition Height="Auto"/> <!-- 輸入區 -->
                </Grid.RowDefinitions>

                <!-- 對話歷史 -->
                <ScrollViewer x:Name="ChatScrollViewer"
                              Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,12">
                    <ItemsControl x:Name="ChatList" ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="user">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="system">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource SystemMessageTemplate}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 建置中橫幅 -->
                <Border Grid.Row="1"
                        Background="#1A1F28"
                        BorderBrush="{StaticResource AccentOrange}"
                        BorderThickness="0,1,0,0"
                        Padding="16,8"
                        Visibility="{Binding IsApiNotReady, Converter={x:Static local:BoolToVisibility.Instance}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🚧" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Foreground="{StaticResource AccentOrange}"
                                   FontSize="12"
                                   VerticalAlignment="Center">
                            <Run Text="AI 引擎建置中 — 填入 API Key 後即可啟用對話功能"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 輸入區 -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,1,0,0"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- API 連線設定區 -->
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8"
                                    Visibility="{Binding IsConfigVisible, Converter={x:Static local:BoolToVisibility.Instance}}">
                            <!-- Endpoint -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="API Endpoint："
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Height="28"
                                         ToolTip="OpenAI 相容的端點，例如 https://api.openai.com/v1/chat/completions"/>
                            </Grid>
                            
                            <!-- Model Name -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="模型名稱："
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Height="28"
                                         ToolTip="例如 gpt-4o, gemini-1.5-pro, qwen2.5 等"/>
                            </Grid>

                            <!-- API Key 與連線 -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="API Key："
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Height="28"
                                         ToolTip="輸入您的 API 金鑰（儲存時會進行 Base64 加密編碼）"/>
                                <Button Grid.Column="2"
                                        Style="{StaticResource BtnPrimary}"
                                        Content="確認連線"
                                        Margin="8,0,0,0"
                                        Height="28"
                                        Command="{Binding ConnectApiCommand}"
                                        Padding="15,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- 對話輸入框 -->
                        <TextBox Grid.Row="1" Grid.Column="0"
                                 x:Name="InputBox"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsApiReady}"
                                 AcceptsReturn="False"
                                 Height="42"
                                 VerticalContentAlignment="Center"
                                 KeyDown="InputBox_KeyDown">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <Button Grid.Row="1" Grid.Column="1"
                                Style="{StaticResource BtnPrimary}"
                                Command="{Binding SendMessageCommand}"
                                Content="▶  送出"
                                Height="42"
                                Margin="8,0,0,0"
                                IsEnabled="{Binding IsApiReady}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── 底部狀態列 ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Development Tools — AI 模型分析助手 v0.1 (建置中)"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Style="{StaticResource BtnSecondary}"
                        Content="清除對話"
                        Command="{Binding ClearChatCommand}"
                        Height="24"
                        Padding="10,2"
                        FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
